{
	"name": "@slideheroes/playwright-mcp",
	"version": "1.0.0",
	"description": "SlideHeroes Playwright MCP server using official Cloudflare implementation",
	"main": "dist/index.js",
	"scripts": {
		"build": "echo 'Skipping tsc build for Cloudflare Worker - use wrangler for deployment'",
		"build:worker": "wrangler deploy --dry-run --outdir dist",
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"type-check": "tsc --noEmit",
		"types": "wrangler types"
	},
	"dependencies": {
		"@cloudflare/playwright": "^0.0.11",
		"@cloudflare/playwright-mcp": "^0.0.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20241218.0",
		"@types/node": "^24.0.4",
		"typescript": "^5.9.2",
		"wrangler": "^4.19.1"
	},
	"keywords": [
		"playwright",
		"mcp",
		"cloudflare",
		"browser-automation",
		"slideheroes"
	],
	"author": "SlideHeroes Team",
	"license": "MIT"
}
