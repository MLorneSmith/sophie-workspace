{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"allowJs": true,
		"checkJs": false,
		"declaration": true,
		"declarationMap": true,
		"skipLibCheck": true,
		"strict": true,
		"outDir": "dist",
		"types": ["@cloudflare/workers-types"],
		"preserveSymlinks": true,
		"maxNodeModuleJsDepth": 2
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
