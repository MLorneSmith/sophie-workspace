{
	"name": "@kit/shared",
	"private": true,
	"version": "0.1.0",
	"scripts": {
		"clean": "git clean -xdf .turbo node_modules",
		"format": "prettier --check \"**/*.{ts,tsx}\"",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"build": "tsc",
		"test": "vitest",
		"test:unit": "vitest run"
	},
	"prettier": "@kit/prettier-config",
	"exports": {
