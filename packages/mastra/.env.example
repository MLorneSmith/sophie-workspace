# Bifrost Gateway Configuration
# Route all Mastra agent LLM calls through Bifrost AI Gateway

# Gateway URL (default: https://gateway.slideheroes.com/v1)
# Leave unset for local development without Bifrost
BIFROST_GATEWAY_URL=

# Cloudflare Access credentials for Bifrost authentication
BIFROST_CF_ACCESS_CLIENT_ID=
BIFROST_CF_ACCESS_CLIENT_SECRET=

# Mastra Database Connection
# Required for agent memory and storage
MASTRA_PG_CONNECTION_STRING=

# Optional: Override default embedding model
# MASTRA_EMBEDDING_MODEL=openai/text-embedding-3-small
