{
	"name": "@kit/admin",
	"private": true,
	"version": "0.1.0",
	"scripts": {
		"clean": "git clean -xdf .turbo node_modules",
		"format": "prettier --check \"**/*.{ts,tsx}\"",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
