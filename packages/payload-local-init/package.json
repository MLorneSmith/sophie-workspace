{
  "name": "@slideheroes/payload-local-init",
  "version": "1.0.0",
  "description": "Scripts and data for local Payload CMS initialization",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed:courses": "pnpm exec tsx ./stage-2-seed-core/seed-courses.ts",
    "seed:course-lessons": "pnpm exec tsx ./stage-2-seed-core/seed-course-lessons.ts",
    "seed:course-quizzes": "pnpm exec tsx ./stage-2-seed-core/seed-course-quizzes.ts",
    "seed:quiz-questions": "pnpm exec tsx ./stage-2-seed-core/seed-quiz-questions.ts",
    "seed:documentation": "pnpm exec tsx ./stage-2-seed-core/seed-documentation.ts",
    "seed:posts": "pnpm exec tsx ./stage-2-seed-core/seed-posts.ts",
    "seed:private": "pnpm exec tsx ./stage-2-seed-core/seed-private.ts",
    "seed:downloads": "pnpm exec tsx ./stage-2-seed-core/seed-downloads.ts",
    "seed:media": "pnpm exec tsx ./stage-2-seed-core/seed-media.ts",
    "seed:surveys": "pnpm exec tsx ./stage-2-seed-core/seed-surveys.ts",
    "seed:survey-questions": "pnpm exec tsx ./stage-2-seed-core/seed-survey-questions.ts",
    "clean:stage2": "rimraf ./dist",
    "stage2:build": "pnpm run clean:stage2 && esbuild ./stage-2-seed-core/run-stage-2.ts --bundle --outfile=dist/run-stage-2.js --platform=node --format=esm --external:payload --external:@payloadcms/db-postgres --external:pg",
    "stage2:run-built": "node ./dist/run-stage-2.js",
    "stage2:seed-all": "pnpm run stage2:build && pnpm run stage2:run-built",
    "verify:counts": "pnpm exec tsx ./stage-4-verification/verify-document-counts.ts",
    "verify:relationships": "pnpm exec tsx ./stage-4-verification/verify-relationships.ts",
    "verify:related-item-counts": "pnpm exec tsx ./stage-4-verification/verify-related-item-counts.ts",
    "stage3:populate-relationships": "tsx ./stage-3-populate-relationships/run-stage-3.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@payloadcms/db-postgres": "^3.37.0",
    "@types/glob": "^8.1.0",
    "@types/uuid": "^9.0.7",
    "esbuild": "^0.25.4",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "payload": "^3.37.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.1",
    "tsx": "^4.7.1",
    "uuid": "^9.0.1"
  }
}
