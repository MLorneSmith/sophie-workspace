{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "sourceMap": true,
    "declaration": false,
    "noEmit": false,
    "isolatedModules": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "./stage-2-seed-core/run-stage-2.ts",
    "../../../apps/payload/src/payload.seeding.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
