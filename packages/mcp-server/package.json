{
	"name": "@kit/mcp-server",
	"private": true,
	"version": "0.1.0",
	"main": "./build/index.js",
	"bin": {
		"makerkit-mcp-server": "./build/index.js"
	},
	"typesVersions": {
		"*": {
			"*": [
				"src/*"
			]
		}
	},
	"scripts": {
