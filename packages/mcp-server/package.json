	},
	"dependencies": {
		"@kit/shared": "workspace:*"
	},
	"devDependencies": {
		"@kit/tsconfig": "workspace:*",
		"@modelcontextprotocol/sdk": "1.23.0",
		"@types/node": "catalog:",
		"zod": "3.23.8"
	}
}
