# Bifrost Gateway Environment Configuration
# Copy this file to .env and fill in your actual API keys

# OpenAI Provider Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Provider Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Bifrost Runtime Configuration
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=info

# Cloudflare Tunnel Configuration (for external access)
# These will be configured when setting up the tunnel
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
# CLOUDFLARE_ACCESS_SERVICE_TOKEN=your-service-token-here
# BIFROST_EXTERNAL_URL=https://bifrost.slideheroes.com
