{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"maxSize": 2097152,
		"ignore": [
			".next/**",
			"dist/**",
			"build/**",
			"node_modules/**",
			"*.min.js",
			"*.bundle.js",
			".vscode/PrimeSelections.json",
			"**/.next/**",
			"**/dist/**",
			"**/build/**",
			"coverage/**",
			"test-results/**",
			"playwright-report/**",
			"packages/playwright-mcp/temp-playwright-mcp/**",
			"apps/payload/payload-types.ts"
		]
	},
	"formatter": { "enabled": true, "indentStyle": "tab" },
	"organizeImports": { "enabled": true },
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"javascript": { "formatter": { "quoteStyle": "double" } }
}