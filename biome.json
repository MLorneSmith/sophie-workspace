{
	"$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"maxSize": 2097152,
		"includes": [
			"**",
			"!**/.next/**",
			"!**/dist/**",
			"!**/build/**",
			"!**/node_modules/**",
			"!**/*.min.js",
			"!**/*.bundle.js",
			"!**/.vscode/PrimeSelections.json",
			"!**/coverage/**",
			"!**/test-results/**",
			"!**/playwright-report/**",
			"!**/packages/playwright-mcp/temp-playwright-mcp/**",
			"!**/apps/payload/payload-types.ts",
			"!**/apps/payload/src/app/(payload)/admin/importMap.js",
			"!**/z.docs/**",
			"!**/z.old/**",
			"!**/z.test/**",
			"!**/turbo/generators/**"
		]
	},
	"formatter": { "enabled": true, "indentStyle": "tab" },
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"security": {
				"noDangerouslySetInnerHtml": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noArrayIndexKey": "error",
				"noConsole": {
					"level": "error",
					"options": {
						"allow": []
					}
				}
			},
			"style": {
				"noUnusedTemplateLiteral": "error",
				"useImportType": "error"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			},
			"nursery": {
				"useUniqueElementIds": "error"
			}
		}
	},
	"javascript": { "formatter": { "quoteStyle": "double" } },
	"overrides": [
		{
			"includes": ["packages/cms/payload/src/content-renderer.tsx"],
			"linter": {
				"rules": {
					"security": {
						"noDangerouslySetInnerHtml": "off"
					}
				}
			}
		},
		{
			"includes": ["**/tests/**/*.ts", "**/tests/**/*.tsx", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx", "**/load-tests/**/*.js"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					},
					"complexity": {
						"useDateNow": "off"
					},
					"correctness": {
						"noUnusedVariables": "off"
					}
				}
			}
		}
	]
}
