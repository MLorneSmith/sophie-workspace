{
	"$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"maxSize": 2097152,
		"includes": [
			"**",
			"!**/.vercel/cache",
			"!**/.next",
			"!**/.next.old",
			"!**/.pnpm-store",
			"!**/logs",
			"!**/dist",
			"!**/build",
			"!**/node_modules",
			"!**/.venv",
			"!**/__pycache__",
			"!**/*.min.js",
			"!**/*.bundle.js",
			"!**/.vscode/PrimeSelections.json",
			"!**/coverage",
			"!**/test-results",
			"!**/playwright-report",
			"!**/apps/payload/payload-types.ts",
			"!**/apps/payload/src/payload-generated-schema.ts",
			"!**/packages/cms/types/src/payload-types.ts",
			"!**/apps/payload/src/app/(payload)/admin/importMap.js",
			"!**/apps/payload/src/migrations",
			"!**/apps/payload/.migrations-backup*",
			"!**/apps/payload/src/seed",
			"!**/z.docs",
			"!**/z.old",
			"!**/z.test",
			"!**/turbo/generators",
			"!**/.turbo",
			"!**/.old.claude",
			"!**/styles/globals.css",
			"!**/supabase/templates/**/*.html",
			"!**/apps/e2e/.auth",
			"!**/.ai/tools/context7/.cache",
			"!**/temp",
			"!**/.ai/alpha/scripts/node_modules.bak",
			"!**/.ai/alpha/progress/*.json",
			"!**/.initiative-progress.json",
			"!**/.ai/alpha/specs",
			"!**/.ai/alpha/archive/**/*.json",
			"!**/.claude/skills/email-style",
			"!**/.github/skills",
			"!**/.agents/skills/nano-banana-pro-prompts-recommend-skill/references",
			"!**/.claude/skills/nano-banana-pro-prompts-recommend-skill/references",
			"!**/.claude/skills/artifacts-builder",
			"!**/packages/mastra/src/rag/playbook-content"
		]
	},
	"formatter": { "enabled": true, "indentStyle": "tab" },
	"css": {
		"parser": {
			"tailwindDirectives": true
		},
		"linter": {
			"enabled": true
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"security": {
				"noDangerouslySetInnerHtml": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noArrayIndexKey": "error",
				"noConsole": {
					"level": "error",
					"options": {
						"allow": []
					}
				}
			},
			"style": {
				"noUnusedTemplateLiteral": "error",
				"useImportType": "error"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"useUniqueElementIds": "error"
			}
		}
	},
	"javascript": { "formatter": { "quoteStyle": "double" } },
	"overrides": [
		{
			"includes": ["packages/cms/payload/src/content-renderer.tsx"],
			"linter": {
				"rules": {
					"security": {
						"noDangerouslySetInnerHtml": "off"
					}
				}
			}
		},
		{
			"includes": ["apps/dev-tool/app/components/components/*-story.tsx"],
			"linter": {
				"rules": {
					"correctness": {
						"useUniqueElementIds": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/tests/**/*.ts",
				"**/tests/**/*.tsx",
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/*.spec.ts",
				"**/*.spec.tsx",
				"**/apps/load-tests/**/*.js",
				"apps/load-tests/**/*.js",
				"**/test-*.ts",
				"**/test-*.tsx",
				"**/vitest.config.mts",
				"**/vitest.config.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noExplicitAny": "off"
					},
					"complexity": {
						"useDateNow": "off",
						"useLiteralKeys": "off",
						"noBannedTypes": "off"
					},
					"correctness": {
						"noUnusedVariables": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/.ai/ai_scripts/**/*.js",
				"**/.ai/ai_scripts/**/*.cjs",
				"**/.ai/tools/**/*.ts",
				"**/.ai/tools/**/*.js",
				"**/.claude/scripts/**/*.js",
				"**/.claude/scripts/**/*.cjs",
				"**/.claude/skills/**/tools/**/*.ts",
				"**/.claude/skills/**/tools/**/*.js",
				"**/scripts/**/*.js",
				"**/scripts/**/*.cjs",
				"**/scripts/**/*.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noAssignInExpressions": "off"
					},
					"style": {
						"useTemplate": "off",
						"noNonNullAssertion": "off"
					},
					"correctness": {
						"noUnusedVariables": "off"
					}
				}
			}
		},
		{
			"includes": ["**/cookie.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noDocumentCookie": "off"
					}
				}
			}
		},
		{
			"includes": ["**/dropzone.tsx"],
			"linter": {
				"rules": {
					"performance": {
						"noImgElement": "off"
					}
				}
			}
		},
		{
			"includes": ["apps/payload/src/seed/seed-data/**/*.json"],
			"formatter": {
				"enabled": false
			},
			"linter": {
				"enabled": false
			},
			"json": {
				"formatter": {
					"enabled": false
				}
			}
		},
		{
			"includes": ["packages/ui/src/**/*.tsx", "packages/ui/src/**/*.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noNestedComponentDefinitions": "off"
					}
				}
			}
		},
		{
			"includes": ["**/test-color-debug.html"],
			"linter": {
				"enabled": false
			}
		},
		{
			"includes": ["packages/ui/src/shadcn/**/*.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["packages/ui/src/makerkit/**/*.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["packages/ui/src/aceternity/**/*.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"noSvgWithoutTitle": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["**/styles/globals.css"],
			"formatter": {
				"enabled": false
			},
			"linter": {
				"enabled": false
			}
		},
		{
			"includes": ["**/*.service.ts", "**/enhanced-logger.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedPrivateClassMembers": "off"
					}
				}
			}
		},
		{
			"includes": ["**/supabase/templates/**/*.html"],
			"linter": {
				"enabled": false
			}
		},
		{
			"includes": ["**/app/(marketing)/_components/section-skeleton.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/app/(marketing)/_components/**/*.tsx",
				"**/app/(marketing)/_lib/**/*.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noArrayIndexKey": "off"
					},
					"a11y": {
						"noSvgWithoutTitle": "off",
						"useAriaPropsSupportedByRole": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/app/home/(user)/_lib/**/*.ts",
				"**/app/home/(user)/_lib/**/*.tsx"
			],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	]
}
