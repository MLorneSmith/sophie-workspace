{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"maxSize": 2097152,
		"ignore": [
			".next/**",
			"dist/**",
			"build/**",
			"node_modules/**",
			"*.min.js",
			"*.bundle.js",
			".vscode/PrimeSelections.json",
			"**/.next/**",
			"**/dist/**",
			"**/build/**",
			"coverage/**",
			"test-results/**",
			"playwright-report/**",
			"packages/playwright-mcp/temp-playwright-mcp/**",
			"apps/payload/payload-types.ts",
			"apps/payload/src/app/(payload)/admin/importMap.js",
			"z.docs/**",
			"z.old/**",
			"z.test/**",
			"turbo/generators/**"
		]
	},
	"formatter": { "enabled": true, "indentStyle": "tab" },
	"organizeImports": { "enabled": true },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"security": {
				"noDangerouslySetInnerHtml": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noArrayIndexKey": "warn"
			}
		}
	},
	"javascript": { "formatter": { "quoteStyle": "double" } }
}
