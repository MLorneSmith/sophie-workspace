# OpenCommit ignore patterns
# Files that should be excluded from AI commit message generation

# Large migration files (JSON files are typically auto-generated and very large)
**/migrations/*.json
**/migrations/*_*.json
apps/payload/src/migrations/*.json

# Large auto-generated files
payload-types.ts
payload-types.js
*.tsbuildinfo

# Certificate files (binary/large)
*.crt
*.key
*.pem

# Large data files
*.sql
*.db
*.sqlite
*.sqlite3

# Build artifacts
dist/
build/
.next/
out/

# Package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Large log files
*.log
logs/

# Media files
/media
/uploads
/public/uploads
*.jpg
*.jpeg
*.png
*.gif
*.svg
*.mp4
*.mp3
*.pdf

# Documentation that doesn't need AI commit messages
*.md
README*
CHANGELOG*
LICENSE*

# Configuration files that are typically large
*.config.js
*.config.ts
next.config.*
turbo.json
