{
	"name": "slideheroes",
	"version": "2.13.1",
	"private": true,
	"sideEffects": false,
	"engines": {
		"node": ">=v18.18.0"
	},
	"author": {
		"url": "https://makerkit.dev",
		"name": "MakerKit"
	},
	"scripts": {
		"turbo": "turbo",
		"postinstall": "pnpm run --filter scripts requirements && manypkg fix",
		"prebuild": "[ -f ./fix-build-permissions.sh ] && ./fix-build-permissions.sh || true",
		"build": "./.claude/statusline/build-wrapper.sh turbo build --cache-dir=.turbo",
		"clean": "git clean -xdf node_modules dist .next",
		"clean:workspaces": "turbo clean",
		"dev": "cross-env FORCE_COLOR=1 turbo dev --parallel",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"lint": "biome lint . && manypkg check && pnpm lint:yaml && pnpm lint:md",
		"lint:fix": "biome lint --write . && manypkg fix && pnpm lint:md:fix",
		"typecheck": "./.claude/statusline/typecheck-wrapper.sh",
		"test": "turbo test --cache-dir=.turbo --filter=!web-e2e",
		"update": "pnpm update -r",
		"syncpack:list": "pnpm dlx syncpack list-mismatches",
		"syncpack:fix": "pnpm dlx syncpack fix-mismatches",
		"supabase:web:start": "pnpm --filter web supabase:start",
		"supabase:web:stop": "pnpm --filter web supabase:stop",
		"supabase:web:typegen": "pnpm --filter web supabase:typegen",
		"supabase:web:reset": "pnpm --filter web supabase:reset",
		"supabase:web:test": "pnpm --filter web supabase:test",
		"stripe:listen": "pnpm --filter '@kit/stripe' start",
		"env:generate": "turbo gen env",
		"env:validate": "turbo gen validate-env",
		"build:raw": "turbo build --cache-dir=.turbo",
		"lint:yaml": "npx yaml-lint '**/*.{yml,yaml}' --ignore='**/node_modules/**' --ignore='**/.next/**' --ignore='**/dist/**'",
		"lint:md": "markdownlint-cli2 '**/*.md' '!node_modules' '!**/node_modules' '!.ai/**' '!.old.claude/**' '!.claude/**' '!.mcp-servers/**' '!.roo/**' '!temp/**' '!**/playwright-report/**' '!**/reports/**' '!**/.reports/**' '!**/test-results/**' '!CLAUDE.md'",
		"lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '!node_modules' '!**/node_modules' '!.ai/**' '!.old.claude/**' '!.claude/**' '!.mcp-servers/**' '!.roo/**' '!temp/**' '!**/playwright-report/**' '!**/reports/**' '!**/.reports/**' '!**/test-results/**' '!CLAUDE.md'",
		"codecheck": "./.claude/statusline/codecheck-wrapper.sh \"pnpm typecheck && pnpm lint && pnpm format\"",
		"typecheck:raw": "turbo typecheck --affected --cache-dir=.turbo",
		"test:unit": "turbo test --cache-dir=.turbo --filter=!web-e2e --continue",
		"test:coverage": "turbo test:coverage --cache-dir=.turbo --filter=!web-e2e",
		"test:e2e": "turbo test --filter=web-e2e",
		"ci-metrics:collect": "node scripts/ci/collect-ci-metrics.js",
		"fetch-questions-temp": "tsx fetch-questions-temp.ts",
		"manypkg:check": "manypkg check",
		"manypkg:fix": "manypkg fix",
		"payload:migrate:ssl": "PAYLOAD_ENABLE_SSL=true pnpm --filter payload payload migrate",
		"payload:migrate:production": "PAYLOAD_MIGRATION_MODE=production pnpm --filter payload payload migrate",
		"prepare": "husky",
		"commit": "cz",
		"knip": "knip",
		"knip:production": "knip --production",
		"knip:workspace": "knip --workspace",
		"knip:fix": "knip --fix",
		"a11y:test": "turbo a11y:test",
		"a11y:report": "turbo a11y:report",
		"e2b:build:dev": "cd packages/e2b/e2b-template && npx tsx build.dev.ts",
		"e2b:build:prod": "cd packages/e2b/e2b-template && npx tsx build.prod.ts"
	},
	"lint-staged": {
		"*": [
			"bash ./scripts/git/trufflehog-scan.sh"
		],
		"apps/payload/**/*.{js,jsx,ts,tsx,json}": [
			"bash -c 'if [[ \"$0\" != *\"/src/seed/\"* ]]; then cd apps/payload && pnpm lint; fi'"
		],
		"packages/**/*.{js,jsx,ts,tsx,json}": [
			"bash -c 'package_dir=$(dirname \"$0\" | cut -d/ -f1-2); if [ -f \"$package_dir/package.json\" ] && grep -q \"\\\"lint\\\"\" \"$package_dir/package.json\"; then cd \"$package_dir\" && pnpm lint; fi'"
		],
		"*.{js,jsx,ts,tsx,json,css}": [
			"bash -c 'if [[ \"$0\" != */apps/payload/* ]] && [[ \"$0\" != */packages/* ]] && [[ \"$0\" != */.ai/alpha/progress/* ]] && [[ \"$0\" != */.ai/alpha/specs/* ]] && [[ \"$0\" != */.initiative-progress.json ]] && [[ \"$0\" != */spec-manifest.json ]]; then biome format --write \"$0\" && biome lint --write \"$0\"; fi'"
		],
		"**/*.{md,mdx}": [
			"bash -c 'if ! echo \"$0\" | grep -qE \"(\\.claude|\\.mcp-servers|\\.roo|\\.ai)/\"; then markdownlint-cli2 --fix \"$0\"; fi'"
		],
		"**/*.{yaml,yml}": [
			"bash -c 'if [[ \"$0\" != *\"pnpm-lock.yaml\"* ]]; then npx yamllint \"$0\"; fi'"
		],
		"**/*.{ts,tsx}": [
			"bash ./scripts/git/type-check-staged.sh"
		]
	},
	"packageManager": "pnpm@10.14.0",
	"pnpm": {
		"overrides": {
			"diff": ">=8.0.3",
			"undici": ">=7.18.2",
			"preact": ">=10.27.3",
			"qs": ">=6.14.1",
			"baseline-browser-mapping": "2.8.32",
			"react-is": "19.0.0",
			"require-in-the-middle": "7.5.2",
			"import-in-the-middle": "1.15.0",
			"tar-fs": "^3.1.1",
			"tar": "^7.5.2",
			"dompurify": "^3.2.4",
			"lexical": "0.35.0",
			"@lexical/clipboard": "0.35.0",
			"@lexical/code": "0.35.0",
			"@lexical/dragon": "0.35.0",
			"@lexical/hashtag": "0.35.0",
			"@lexical/headless": "0.35.0",
			"@lexical/history": "0.35.0",
			"@lexical/html": "0.35.0",
			"@lexical/link": "0.35.0",
			"@lexical/list": "0.35.0",
			"@lexical/mark": "0.35.0",
			"@lexical/markdown": "0.35.0",
			"@lexical/offset": "0.35.0",
			"@lexical/overflow": "0.35.0",
			"@lexical/plain-text": "0.35.0",
			"@lexical/react": "0.35.0",
			"@lexical/rich-text": "0.35.0",
			"@lexical/selection": "0.35.0",
			"@lexical/table": "0.35.0",
			"@lexical/text": "0.35.0",
			"@lexical/utils": "0.35.0",
			"@lexical/yjs": "0.35.0",
			"nodemailer": "^7.0.11"
		},
		"patchedDependencies": {
			"payload@3.70.0": "patches/payload@3.70.0.patch"
		}
	},
	"devDependencies": {
		"@ast-grep/napi": "^0.40.0",
		"@biomejs/biome": "2.3.8",
		"@commitlint/cli": "^20.2.0",
		"@commitlint/config-conventional": "^20.2.0",
		"@e2b/code-interpreter": "^2.3.1",
		"@manypkg/cli": "^0.25.1",
		"@playwright/test": "^1.57.0",
		"@turbo/gen": "^2.6.3",
		"@vitest/coverage-v8": "^4.0.14",
		"codebase-map": "^0.6.1",
		"commitizen": "^4.3.1",
		"cross-env": "^10.1.0",
		"cz-conventional-changelog": "^3.3.0",
		"fuse.js": "^7.1.0",
		"graph-data-structure": "^4.5.0",
		"husky": "^9.1.7",
		"ink": "^6.6.0",
		"ink-spinner": "^5.0.0",
		"js-yaml": "^4.1.1",
		"knip": "^5.72.0",
		"lint-staged": "^16.2.7",
		"markdownlint-cli2": "^0.20.0",
		"patch-package": "^8.0.0",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"tailwind-merge": "^3.4.0",
		"turbo": "2.6.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.15",
		"yaml-lint": "^1.7.0"
	}
}
