# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0

# Configuration for Snyk vulnerability scanning
# This file ensures parity with CI/CD configuration in .github/workflows/pr-validation.yml

# Patches for known vulnerabilities (empty initially, will be populated as needed)
patches: []

# Ignore specific vulnerabilities (use sparingly and with clear justification)
# Format: 
# ignore:
#   SNYK-JS-PACKAGENAME-1234567:
#     - '*':
#         reason: 'Clear explanation of why this is ignored'
#         expires: '2025-12-31T23:59:59.999Z'
ignore: {}

# Exclude paths from scanning to match CI/CD behavior
exclude:
  # Global exclusions apply to all Snyk products
  global:
    # Build outputs and generated files
    - 'dist/**'
    - 'build/**'
    - '.next/**'
    - 'out/**'
    - 'coverage/**'
    - '.turbo/**'
    - 'node_modules/**'
    - '.pnpm-store/**'
    
    # Test directories (still scan their dependencies)
    - '**/test/**'
    - '**/tests/**'
    - '**/__tests__/**'
    - '**/e2e/**'
    - '**/fixtures/**'
    - '**/mocks/**'
    - '**/__mocks__/**'
    
    # Development and tooling directories
    - '.storybook/**'
    - '.vscode/**'
    - '.idea/**'
    - 'tooling/**'
    - 'scripts/**'
    
    # Claude and MCP specific directories
    - '.claude/**'
    - '.mcp-servers/**'
    - '.roo/**'
    
    # Documentation
    - 'docs/**'
    - '**/*.md'
    
    # Temporary and cache files
    - '**/.cache/**'
    - '**/tmp/**'
    - '**/temp/**'
    
  # Code-specific exclusions (for Snyk Code SAST scanning)
  code:
    # Test files
    - '**/*.test.ts'
    - '**/*.test.tsx'
    - '**/*.test.js'
    - '**/*.test.jsx'
    - '**/*.spec.ts'
    - '**/*.spec.tsx'
    - '**/*.spec.js'
    - '**/*.spec.jsx'
    
    # Configuration files
    - '**/*.config.js'
    - '**/*.config.ts'
    - '**/*.config.mjs'
    - '**/rollup.config.js'
    - '**/webpack.config.js'
    - '**/vite.config.ts'
    - '**/vitest.config.ts'
    
    # Generated files
    - '**/generated/**'
    - '**/*.generated.ts'
    - '**/schema.graphql'
    - '**/schema.json'