# Turbo Remote Cache Security
# This key signs cached artifacts to ensure they haven't been tampered with
# Generate a new key with: openssl rand -hex 32
# REQUIRED for secure remote caching - without this, cache artifacts could be compromised
TURBO_REMOTE_CACHE_SIGNATURE_KEY=your_signature_key_here

# Snyk Configuration
# To get your token: 
# 1. Run: pnpm audit:auth
# 2. Or visit: https://app.snyk.io/account
SNYK_TOKEN=your_snyk_token_here

# Test Environment Configuration
# For test scripts, create a .env.test file with test credentials
# See scripts/README.md for details

# MCP Server API Keys (optional - only needed if you enable these servers in .mcp.json)
# Exa Search API - Get your key at: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here
# Perplexity API - Get your key at: https://perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here
# New Relic - Get your key at: https://one.newrelic.com/api-keys
NEW_RELIC_API_KEY=your_new_relic_api_key_here
NEW_RELIC_ACCOUNT_ID=your_account_id_here

# Alpha Orchestrator - Prerequisites
# The orchestrator requires Python 3.8+ with specific packages for the event server.
# Install them with: pip install -r .ai/alpha/scripts/python-requirements.txt
# The orchestrator will attempt automatic installation if packages are missing.

# Alpha Orchestrator - Sandbox Supabase Project
# Create a free Supabase project for E2B sandbox testing
# This is separate from your production database
# Get credentials at: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_SANDBOX_PROJECT_REF=your_project_ref_here
SUPABASE_SANDBOX_URL=https://your_project_ref.supabase.co
SUPABASE_SANDBOX_ANON_KEY=your_anon_key_here
SUPABASE_SANDBOX_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_SANDBOX_DB_URL=postgresql://postgres.your_project_ref:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Supabase CLI Access Token (for linking projects)
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_cli_access_token_here

# Payload CMS Credentials (for E2B sandbox seeding)
# These enable Payload CMS migrations and seeding in E2B sandboxes
# Copy from apps/payload/.env or use consistent values across environments
PAYLOAD_SECRET=your_payload_secret_here
SEED_USER_PASSWORD=your_seed_user_password_here

# R2 Storage Configuration (for E2B sandbox seeding)
# Required for seeding media files - copy from apps/payload/.env
# Get credentials from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ACCOUNT_ID=your_r2_account_id_here
R2_MEDIA_BUCKET=media
R2_DOWNLOADS_BUCKET=downloads
R2_REGION=auto
PAYLOAD_PUBLIC_MEDIA_BASE_URL=https://media.yourdomain.com
PAYLOAD_PUBLIC_DOWNLOADS_BASE_URL=https://downloads.yourdomain.com