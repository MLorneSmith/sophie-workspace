# AI Ignore Patterns
# Prevents Claude Code from accessing sensitive files
# Based on ClaudeKit's file-guard patterns

# Environment files
*.env
*.env.*
.env*
env.local
env.production
env.development

# Private keys and certificates
*.key
*.pem
*.p12
*.pfx
*.cert
*.crt
*.der
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
*.pub

# SSH and Git configs
.ssh/*
.git/config
.gitconfig

# Package manager configs
.npmrc
.yarnrc
pnpm-workspace.yaml

# Authentication and secrets
*.secret
*secret*
*password*
*token*
*apikey*
*api_key*
*private*
.netrc

# Cloud provider configs
.aws/*
.gcloud/*
.azure/*
.docker/config.json
kubeconfig
*.tfvars

# Database files
*.sqlite
*.sqlite3
*.db
*.sql

# Backup files
*.bak
*.backup
*~

# Project-specific sensitive files
apps/web/.env*
apps/payload/.env*
packages/database/migrations/*.sql
supabase/.env
supabase/seed.sql

# Custom patterns (add your own below)