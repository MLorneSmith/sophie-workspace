#!/bin/bash
# Balanced Hook Configuration - Optimized for Token Usage
# This configuration reduces hook overhead by ~90% while maintaining code quality

# Hook mode: development, balanced, or strict
HOOK_MODE=balanced

# Format hooks: Disabled to save tokens (cosmetic only)
DISABLE_FORMAT_HOOKS=true

# Lint hooks: Enabled but throttled for important checks
DISABLE_LINT_HOOKS=false

# Only check these file extensions (comma-separated)
CHECK_EXTENSIONS="ts,tsx,js,jsx"

# Throttle hook execution to every 5 minutes (300 seconds)
HOOK_THROTTLE_SECONDS=300

# Batch size: Only run after this many files change
HOOK_BATCH_SIZE=5

# Skip patterns (comma-separated glob patterns)
SKIP_PATTERNS="*.test.ts,*.test.tsx,*.spec.ts,*.spec.tsx,*.d.ts,temp/*,.claude/*"

# Only run hooks on these events (comma-separated)
RUN_HOOKS_ON="save,commit,pr"

# Directories to skip entirely
SKIP_DIRECTORIES=".turbo,node_modules,dist,build,.next,.git,temp,.claude/temp"

# Maximum file size to check (in KB) - skip very large files
MAX_FILE_SIZE_KB=500

# Enable verbose output for debugging (set to true for troubleshooting)
VERBOSE=false

# Cache directory for throttling timestamps
HOOK_CACHE_DIR="/tmp/.claude-hooks"

# Create cache directory if it doesn't exist
mkdir -p "$HOOK_CACHE_DIR" 2>/dev/null || true