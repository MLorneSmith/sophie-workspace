# k6 Load Testing Configuration

# Target URL for load testing
K6_API_URL=https://staging.slideheroes.com

# Test user credentials (create dedicated test accounts)
K6_TEST_USER_EMAIL=loadtest@slideheroes.com
K6_TEST_USER_PASSWORD=test123

# New Relic integration (optional)
NEW_RELIC_LICENSE_KEY=your_license_key_here

# k6 binary path (defaults to ../.bin/k6)
K6_BIN=/usr/local/bin/k6

# k6 Cloud project ID (if using k6 Cloud)
K6_PROJECT_ID=your_project_id_here