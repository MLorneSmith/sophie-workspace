# Station Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real API keys to version control

# ============================================
# REQUIRED FOR STATION
# ============================================

# OpenAI API Key (required for Station agents)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# MCP SERVERS VIA STATION
# ============================================

# Perplexity AI for Q&A and research
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here

# Exa for web search
EXA_API_KEY=your-exa-api-key-here

# Supabase Configuration
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-supabase-service-key-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ============================================
# DIRECT MCP SERVERS (NOT VIA STATION)
# ============================================

# PostgreSQL Connection (local Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# NewRelic Monitoring (optional)
NEW_RELIC_API_KEY=your-newrelic-api-key
NEW_RELIC_ACCOUNT_ID=your-newrelic-account-id

# Cloudflare Playwright (optional)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# ============================================
# PROJECT SETTINGS
# ============================================

# Project paths
PROJECT_ROOT=/home/msmith/projects/worktrees/feature-station

# Node environment
NODE_ENV=development

# ============================================
# HOW TO USE THIS FILE
# ============================================
# 1. Copy this file: cp .env.example.station .env
# 2. Fill in your actual API keys and values
# 3. Load before running Station: source .env
# 4. Never commit .env to version control
# 5. Add .env to .gitignore