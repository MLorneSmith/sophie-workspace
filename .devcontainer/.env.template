# SlideHeroes Devcontainer Environment Template
# Copy this file to .env.devcontainer and fill in your values
# These variables will be automatically loaded in the devcontainer

# GitHub Personal Access Token (for GitHub API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Supabase Configuration (for production/staging access)
# Get from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Configuration (optional for payments testing)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email Configuration (optional for email testing)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_SENDER=noreply@slideheroes.com

# Monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# OpenAI Configuration (for AI features)
OPENAI_API_KEY=

# Anthropic Configuration (for Claude integration)
ANTHROPIC_API_KEY=

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Feature Flags
NEXT_PUBLIC_ENABLE_TEAMS=false
NEXT_PUBLIC_ENABLE_BILLING=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# Development Overrides
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
TURBO_TELEMETRY_DISABLED=1