{
	"name": "SlideHeroes Multi-Container Dev Environment",
	// Docker Compose configuration
	// For Codespaces: both docker-compose.yml and docker-compose.codespaces.yml are loaded
	// For local dev: only docker-compose.yml (can manually add docker-compose.local-override.yml if needed)
	"dockerComposeFile": ["docker-compose.yml", "docker-compose.codespaces.yml"],
	"service": "app",
	"workspaceFolder": "/workspace",
	"remoteUser": "node",

	// Features to add to the dev container
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"version": "latest",
			"enableNonRootDocker": "true",
			"moby": "true"
		},
		"ghcr.io/devcontainers-contrib/features/supabase-cli:1": {
			"version": "latest"
		}
	},

	"customizations": {
		"vscode": {
			"extensions": [
				// Claude Code extension (required)
				"Anthropic.claude-code",

				// Code quality
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"biomejs.biome",

				// Git
				"eamodio.gitlens",

				// TypeScript and JavaScript
				"ms-vscode.vscode-typescript-next",
				"christian-kohler.npm-intellisense",
				"christian-kohler.path-intellisense",

				// React and Next.js
				"dsznajder.es7-react-js-snippets",
				"bradlc.vscode-tailwindcss",

				// Database
				"Prisma.prisma",
				"mtxr.sqltools",
				"mtxr.sqltools-driver-pg",

				// Docker
				"ms-azuretools.vscode-docker",

				// Testing
				"vitest.explorer",
				"ms-playwright.playwright",

				// Markdown
				"yzhang.markdown-all-in-one",
				"DavidAnson.vscode-markdownlint",

				// YAML
				"redhat.vscode-yaml",

				// Environment variables
				"mikestead.dotenv"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				"editor.codeActionsOnSave": {
					"source.fixAll.eslint": "explicit"
				},
				"[javascript]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[javascriptreact]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[typescript]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[typescriptreact]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[json]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[jsonc]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"terminal.integrated.defaultProfile.linux": "zsh",
				"terminal.integrated.profiles.linux": {
					"zsh": {
						"path": "/bin/zsh"
					}
				},
				"typescript.tsdk": "node_modules/typescript/lib",
				"typescript.enablePromptUseWorkspaceTsdk": true,
				"tailwindCSS.experimental.classRegex": [
					["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
					["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
				],
				"files.associations": {
					"*.css": "tailwindcss"
				},
				"git.enableSmartCommit": true,
				"git.confirmSync": false
			}
		},
		"codespaces": {
			"repositories": {
				"MLorneSmith/2025slideheroes": {
					"permissions": {
						"contents": "write",
						"pull_requests": "write",
						"issues": "write"
					}
				}
			}
		}
	},

	// Port forwarding for SlideHeroes services
	"forwardPorts": [
		3000, // Next.js development server
		3001, // Next.js HMR
		54321, // Supabase Studio
		54322, // Supabase PostgreSQL
		54323, // Supabase Auth
		54324, // Supabase Storage
		54325, // Supabase Realtime
		54326, // Supabase Meta
		54327, // Supabase Edge Functions
		54328, // Supabase Analytics
		54329, // Supabase Vector
		6006, // Storybook
		6379, // Redis
		8025, // Mailhog UI
		9229, // Node.js debugger
		"3010-3020" // MCP server ports range
	],

	"portsAttributes": {
		"3000": {
			"label": "Next.js App",
			"onAutoForward": "notify",
			"requireLocalPort": true
		},
		"54321": {
			"label": "Supabase Studio",
			"onAutoForward": "notify"
		},
		"54322": {
			"label": "PostgreSQL Database",
			"onAutoForward": "silent"
		},
		"6379": {
			"label": "Redis Cache",
			"onAutoForward": "silent"
		},
		"8025": {
			"label": "Mailhog Email UI",
			"onAutoForward": "notify"
		}
	},

	// Setup commands with proper sequencing
	// initializeCommand runs on the host before containers are created
	"initializeCommand": "bash .devcontainer/scripts/setup-compose-files.sh || true",
	// postCreateCommand runs after container is created
	"postCreateCommand": "bash /workspace/.devcontainer/scripts/post-create.sh",
	// postStartCommand runs each time container starts
	"postStartCommand": "bash /workspace/.devcontainer/scripts/post-start.sh",
	// postAttachCommand runs when VS Code attaches
	"postAttachCommand": "bash /workspace/.devcontainer/scripts/post-attach.sh",

	// GitHub Codespaces configuration
	"hostRequirements": {
		"cpus": 4,
		"memory": "8gb",
		"storage": "32gb"
	},

	// Codespaces-specific settings
	"codespaces": {
		"openFiles": ["README.md", "CLAUDE.md"]
	},

	// User environment variables
	"remoteEnv": {
		"PATH": "/workspace/node_modules/.bin:${containerEnv:PATH}",
		"SHELL": "/bin/zsh"
	},

	// Wait for post-create command to complete
	"waitFor": "postCreateCommand",

	// Shutdown action
	"shutdownAction": "stopCompose"
}
