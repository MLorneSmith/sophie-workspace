{
  "name": "SlideHeroes Development Container",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20-bullseye",
  
  // Features to add to the dev container
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "installDirectlyFromGitHubRelease": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "nodeGypDependencies": true,
      "version": "20"
    },
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": true,
      "username": "vscode",
      "userUid": "1000",
      "userGid": "1000"
    },
    "ghcr.io/devcontainers-contrib/features/pnpm:2": {
      "version": "latest"
    },
    "ghcr.io/devcontainers-contrib/features/supabase-cli:1": {
      "version": "latest"
    }
  },

  // Configure tool-specific properties
  "customizations": {
    "vscode": {
      "extensions": [
        // Claude Code extension
        "Anthropic.claude-code",
        
        // Code quality and formatting
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "biomejs.biome",
        
        // TypeScript and JavaScript
        "ms-vscode.vscode-typescript-next",
        "christian-kohler.npm-intellisense",
        "christian-kohler.path-intellisense",
        
        // React and Next.js
        "dsznajder.es7-react-js-snippets",
        "bradlc.vscode-tailwindcss",
        
        // Database and Prisma
        "Prisma.prisma",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        
        // Docker
        "ms-azuretools.vscode-docker",
        
        // Git
        "eamodio.gitlens",
        "donjayamanne.githistory",
        
        // Testing
        "vitest.explorer",
        "ms-playwright.playwright",
        
        // Markdown
        "yzhang.markdown-all-in-one",
        "DavidAnson.vscode-markdownlint",
        
        // YAML
        "redhat.vscode-yaml",
        
        // Environment variables
        "mikestead.dotenv",
        
        // REST Client
        "humao.rest-client",
        
        // Code navigation
        "sleistner.vscode-fileutils",
        "formulahendry.auto-rename-tag"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        },
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "quickfix.biome": "explicit",
          "source.organizeImports.biome": "explicit"
        },
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[json]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "tailwindCSS.experimental.classRegex": [
          ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
          ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
        ],
        "files.associations": {
          "*.css": "tailwindcss"
        }
      }
    }
  },

  // Port forwarding configuration
  "forwardPorts": [
    3000,     // Next.js development server
    3001,     // Next.js HMR
    54321,    // Supabase Studio
    54322,    // Supabase PostgreSQL
    54323,    // Supabase Auth
    54324,    // Supabase Storage
    54325,    // Supabase Realtime
    54326,    // Supabase Meta
    54327,    // Supabase Edge Functions
    54328,    // Supabase Analytics
    54329,    // Supabase Vector
    6006,     // Storybook
    9229      // Node.js debugger
  ],
  
  "portsAttributes": {
    "3000": {
      "label": "Next.js App",
      "onAutoForward": "notify",
      "requireLocalPort": true
    },
    "54321": {
      "label": "Supabase Studio",
      "onAutoForward": "notify"
    },
    "54322": {
      "label": "PostgreSQL Database",
      "onAutoForward": "silent"
    },
    "6006": {
      "label": "Storybook",
      "onAutoForward": "silent"
    }
  },

  // Container environment variables
  "containerEnv": {
    "NODE_ENV": "development",
    "NEXT_TELEMETRY_DISABLED": "1",
    "FORCE_COLOR": "1",
    "TERM": "xterm-256color",
    "EDITOR": "code --wait",
    "TURBO_TELEMETRY_DISABLED": "1"
  },

  // Workspace mount and work directory
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",

  // Mounts for performance optimization
  "mounts": [
    // Persist node_modules between rebuilds
    "source=slideheroes-node_modules,target=/workspace/node_modules,type=volume",
    
    // Persist pnpm store
    "source=slideheroes-pnpm-store,target=/home/vscode/.pnpm-store,type=volume",
    
    // Persist Next.js cache
    "source=slideheroes-next-cache,target=/workspace/.next,type=volume",
    
    // Persist turbo cache
    "source=slideheroes-turbo-cache,target=/workspace/.turbo,type=volume",
    
    // Persist Supabase data
    "source=slideheroes-supabase-data,target=/workspace/apps/web/.supabase,type=volume",
    
    // Persist MCP servers
    "source=slideheroes-mcp-servers,target=/workspace/.mcp-servers,type=volume",
    
    // Persist Git configuration
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
    
    // Persist SSH keys
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    
    // Persist ZSH history
    "source=slideheroes-zsh-history,target=/home/vscode/.zsh_history,type=volume"
  ],

  // Run commands after container is created
  "postCreateCommand": "/workspace/.devcontainer/scripts/post-create.sh",
  
  // Run commands after container is started
  "postStartCommand": "/workspace/.devcontainer/scripts/post-start.sh",
  
  // Run commands after attach to container
  "postAttachCommand": "/workspace/.devcontainer/scripts/post-attach.sh",

  // Container capabilities
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    "--privileged",
    "--init"
  ],

  // Remote user configuration
  "remoteUser": "vscode",
  
  // Update remote user UID/GID to match local user
  "updateRemoteUserUID": true,

  // Container resource limits (for GitHub Codespaces)
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },

  // Wait for specific processes before marking container as ready
  "waitFor": "postCreateCommand",

  // Shutdown action
  "shutdownAction": "stopContainer",

  // Enable GPU support if available
  "gpus": "all",

  // Features specific configuration
  "capAdd": ["SYS_PTRACE"],
  "securityOpt": ["seccomp=unconfined"],

  // Additional features for development
  "otherPortsAttributes": {
    "onAutoForward": "silent"
  },

  // Lifecycle scripts
  "initializeCommand": "echo 'Initializing SlideHeroes Development Container...'",
  
  // User environment variables (can be overridden)
  "remoteEnv": {
    "PATH": "/workspace/node_modules/.bin:${containerEnv:PATH}",
    "SHELL": "/bin/zsh"
  }
}