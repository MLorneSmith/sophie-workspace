FROM node:20-slim

# Set timezone
ARG TZ=America/Los_Angeles
ENV TZ=$TZ
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# Install base dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    jq \
    netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

# Configure node user (already exists in node:20-slim)
RUN mkdir -p /home/node/.mcp \
    && chown -R node:node /home/node/.mcp

# Switch to node user
USER node

# Set working directory
WORKDIR /workspace

# Environment variables for MCP client access
ENV NODE_ENV=development
ENV MCP_SERVERS_HOST=host.docker.internal

# This container serves as a lightweight MCP client environment
# The actual MCP servers are containerized separately via docker-compose.mcp.yml
# Available MCP servers (when running):
# - mcp-perplexity: localhost:3051
# - mcp-supabase: localhost:3002  
# - mcp-context7: localhost:3003
# - mcp-postgres: localhost:3004
# - mcp-browser-tools: localhost:3005
# - mcp-code-reasoning: localhost:3006
# - mcp-github: localhost:3007
# - mcp-exa-proxy: localhost:3008
# - mcp-cloudflare-observability: localhost:3009
# - mcp-cloudflare-bindings: localhost:3010
# - mcp-cloudflare-playwright: localhost:3011

# Keep container running
CMD ["sleep", "infinity"]