# .secretsignore - TruffleHog false positive exclusions
# Add patterns here for known false positives
# Format: file_path:line_number:secret_hash

# Example patterns for test files and documentation
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/*.stories.tsx
**/test/**
**/tests/**
**/__tests__/**
**/__mocks__/**

# Documentation and examples
**/*.md
**/docs/**
**/examples/**
**/.env.example
**/.env.local.example
**/.env.test

# Build outputs
.next/**
dist/**
build/**
out/**

# Package files
package.json
package-lock.json
pnpm-lock.yaml
yarn.lock

# Known safe patterns
# Public keys (these are meant to be public)
**/NEXT_PUBLIC_*

# Example/dummy values in code comments
# Use specific file:line:hash format for these

# Migrations and seeds (often contain example data)
**/migrations/**
**/seeds/**

# Storybook files
.storybook/**
**/*.stories.ts
**/*.stories.tsx

# CI/CD configs (often have placeholder values)
.github/workflows/*.yml:.env.example
.github/workflows/*.yaml:.env.example

# Docker compose files with example values
docker-compose*.yml
docker-compose*.yaml
.devcontainer/docker-compose*.yml
.devcontainer/docker-compose*.yaml

# Specific false positives (add as needed)
# Format: path/to/file.ts:line_number:secret_fingerprint
# Example: src/config/example.ts:42:a1b2c3d4e5f6...

# PostgreSQL development connection strings (local only)
**/*postgresql://postgres:postgres@*
**/*POSTGRES_PASSWORD=postgres*
**/*JWT_SECRET=your-super-secret-jwt-token*