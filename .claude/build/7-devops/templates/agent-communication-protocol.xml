<?xml version="1.0" encoding="UTF-8"?>
<!--
  Agent Communication Protocol Template
  Defines the standard message format for inter-agent communication
-->
<communication_protocol>
  <message_format>
    <header>
      <message_id>{UUID}</message_id>
      <timestamp>{ISO_8601_TIMESTAMP}</timestamp>
      <from_agent>{SENDER_AGENT_NAME}</from_agent>
      <to_agent>{RECIPIENT_AGENT_NAME}</to_agent>
      <message_type>{REQUEST|RESPONSE|NOTIFICATION|HANDOFF}</message_type>
      <priority>{CRITICAL|HIGH|NORMAL|LOW}</priority>
      <phase>{CURRENT_AAFD_PHASE}</phase>
      <correlation_id>{PARENT_MESSAGE_ID_IF_RESPONSE}</correlation_id>
    </header>
    
    <payload>
      <artifact_reference>
        <type>{PRD|CHUNK|STORY|CODE|VALIDATION_REPORT}</type>
        <id>{ARTIFACT_ID}</id>
        <version>{VERSION_NUMBER}</version>
        <location>{FILE_PATH_OR_GITHUB_REFERENCE}</location>
      </artifact_reference>
      
      <content>
        <!-- Actual message content based on message type -->
        <request_content>
          <action>{VALIDATE|REVIEW|IMPLEMENT|FIX|PLAN}</action>
          <target>{WHAT_TO_ACT_ON}</target>
          <requirements>
            <requirement>{SPECIFIC_REQUIREMENT}</requirement>
          </requirements>
          <constraints>
            <constraint>{TIME|RESOURCE|TECHNICAL_CONSTRAINT}</constraint>
          </constraints>
          <expected_outcome>{WHAT_SUCCESS_LOOKS_LIKE}</expected_outcome>
        </request_content>
        
        <response_content>
          <status>{SUCCESS|PARTIAL|FAILED}</status>
          <result>{OUTCOME_OF_ACTION}</result>
          <issues_found>
            <issue severity="{CRITICAL|HIGH|MEDIUM|LOW}">
              <description>{ISSUE_DESCRIPTION}</description>
              <location>{WHERE_FOUND}</location>
              <suggested_fix>{HOW_TO_RESOLVE}</suggested_fix>
            </issue>
          </issues_found>
          <recommendations>
            <recommendation>{IMPROVEMENT_SUGGESTION}</recommendation>
          </recommendations>
        </response_content>
        
        <notification_content>
          <event_type>{STARTED|COMPLETED|BLOCKED|ESCALATION}</event_type>
          <description>{WHAT_HAPPENED}</description>
          <impact>{WHO_OR_WHAT_AFFECTED}</impact>
          <action_required>{WHAT_OTHERS_NEED_TO_DO}</action_required>
        </notification_content>
      </content>
      
      <context>
        <!-- Relevant context for the message -->
        <project_context>
          <epic_id>{EPIC_NUMBER}</epic_id>
          <chunk_id>{CHUNK_ID}</chunk_id>
          <story_id>{STORY_ID}</story_id>
          <sprint_id>{SPRINT_ID}</sprint_id>
        </project_context>
        
        <technical_context>
          <affected_files>
            <file>{FILE_PATH}</file>
          </affected_files>
          <dependencies>
            <dependency>{LIBRARY_OR_SERVICE}</dependency>
          </dependencies>
          <performance_impact>{EXPECTED_IMPACT}</performance_impact>
        </technical_context>
        
        <quality_context>
          <current_quality_score>{SCORE}</current_quality_score>
          <quality_criteria_applied>{CRITERIA_LIST}</quality_criteria_applied>
          <previous_validations>{HISTORY}</previous_validations>
        </quality_context>
      </context>
    </payload>
    
    <metadata>
      <routing>
        <reply_to>{AGENT_NAME_FOR_RESPONSES}</reply_to>
        <cc_agents>
          <agent>{AGENT_TO_NOTIFY}</agent>
        </cc_agents>
        <escalation_path>{NEXT_AGENT_IF_NO_RESPONSE}</escalation_path>
      </routing>
      
      <timing>
        <response_required_by>{DEADLINE_IF_APPLICABLE}</response_required_by>
        <sla>{SERVICE_LEVEL_AGREEMENT}</sla>
        <timeout_action>{WHAT_TO_DO_IF_NO_RESPONSE}</timeout_action>
      </timing>
      
      <tracking>
        <conversation_id>{THREAD_ID}</conversation_id>
        <sequence_number>{MESSAGE_ORDER_IN_CONVERSATION}</sequence_number>
        <audit_trail>{ENABLED|DISABLED}</audit_trail>
      </tracking>
    </metadata>
  </message_format>
  
  <message_patterns>
    <!-- Common communication patterns -->
    <pattern name="validation_request">
      <description>Request validation from Critic agent</description>
      <from>Any Agent</from>
      <to>Critic Agent</to>
      <message_type>REQUEST</message_type>
      <expected_response_time>15 minutes</expected_response_time>
    </pattern>
    
    <pattern name="issue_escalation">
      <description>Escalate blocking issue to next agent</description>
      <from>Any Agent</from>
      <to>Next Agent in Workflow</to>
      <message_type>NOTIFICATION</message_type>
      <priority>HIGH</priority>
    </pattern>
    
    <pattern name="quality_feedback">
      <description>Provide quality assessment results</description>
      <from>Reviewer/Critic Agent</from>
      <to>Builder/Planner Agent</to>
      <message_type>RESPONSE</message_type>
      <includes_recommendations>true</includes_recommendations>
    </pattern>
  </message_patterns>
  
  <error_handling>
    <scenario type="no_response">
      <timeout_duration>30 minutes</timeout_duration>
      <action>Escalate to next agent in chain</action>
      <notification>Alert human operator</notification>
    </scenario>
    
    <scenario type="invalid_message">
      <action>Return error to sender</action>
      <log_level>ERROR</log_level>
      <retry_allowed>true</retry_allowed>
    </scenario>
    
    <scenario type="agent_unavailable">
      <action>Queue message for later delivery</action>
      <fallback_agent>{BACKUP_AGENT}</fallback_agent>
      <max_retry_attempts>3</max_retry_attempts>
    </scenario>
  </error_handling>
</communication_protocol>