{
	"name": "ccpm-dashboards",
	"version": "1.0.0",
	"description": "CCPM HTML Dashboard Reporting System",
	"type": "module",
	"main": "generator/index.js",
	"scripts": {
		"generate": "node generator/index.js",
		"generate:watch": "nodemon --watch ../tracking --watch generator --exec 'pnpm run generate'",
		"serve": "npx http-server output -p 8080",
		"build": "pnpm run generate && echo 'Dashboards generated successfully'",
		"deploy": "pnpm run generate && echo 'Ready for GitHub Pages deployment'"
	},
	"keywords": [
		"ccpm",
		"dashboard",
		"reporting",
		"project-management"
	],
	"author": "CCPM Team",
	"license": "MIT",
	"dependencies": {
		"chart.js": "^4.5.0",
		"marked": "^12.0.2",
		"mermaid": "^10.9.4",
		"yaml": "^2.8.1"
	},
	"devDependencies": {
		"http-server": "^14.1.1",
		"nodemon": "^3.0.3"
	}
}
