{
	"_comment": "Example settings file - copy to settings.local.json and customize",
	"env": {
		"BASH_DEFAULT_TIMEOUT_MS": "900000",
		"BASH_MAX_TIMEOUT_MS": "1800000"
	},
	"permissions": {
		"allow": [
			"WebSearch",
			"Bash(pnpm build:*)",
			"Bash(DEBUG_TEST=true node .claude/scripts/test/test-controller.cjs --quick --debug)",
			"Read(/tmp/claudekit-repo/src/commands/spec/**)",
			"mcp__code-reasoning__code-reasoning",
			"Read(/tmp/claudekit-repo/src/commands/**)",
			"mcp__exa__exa_search",
			"mcp__perplexity-ask__perplexity_ask",
			"mcp__context7__get-library-docs",
			"Bash(~/.local/bin/codespace-manager.sh:*)",
			"mcp__context7__resolve-library-id",
			"Bash(.claude/scripts/codecheck-direct.sh:*)",
			"Bash(DEBUG_TEST=true node .claude/scripts/test/test-controller.cjs --debug)",
			"WebFetch(domain:docs.warp.dev)",
			"Bash(pnpm lint:*)",
			"Bash(gh run list:*)",
			"Bash(git log:*)",
			"mcp__github__search_issues",
			"mcp__github__list_issues"
		],
		"deny": [],
		"ask": [],
		"additionalDirectories": ["/home/msmith"]
	},
	"enableAllProjectMcpServers": true,
	"enabledMcpjsonServers": [
		"exa",
		"perplexity-ask",
		"supabase",
		"context7",
		"cloudflare-observability",
		"cloudflare-bindings",
		"postgres",
		"browser-tools",
		"code-reasoning",
		"github",
		"newrelic"
	]
}
