{
	"permissions": {
		"allow": [
			"Bash(mkdir:*)",
			"Bash(uv:*)",
			"Bash(find:*)",
			"Bash(mv:*)",
			"Bash(grep:*)",
			"Bash(npm:*)",
			"Bash(ls:*)",
			"Bash(cp:*)",
			"Write",
			"Bash(./scripts/copy_dot_env.sh:*)",
			"Bash(chmod:*)",
			"Bash(touch:*)"
		],
		"deny": [
			"Bash(git push --force:*)",
			"Bash(git push -f:*)",
			"Bash(rm -rf:*)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/validate-commit-message.sh",
						"timeout": 5
					},
					{
						"type": "command",
						"command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/pre_tool_use.py",
						"timeout": 5
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_use.py || true",
						"timeout": 5
					}
				]
			}
		],
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/notification.py --notify || true",
						"timeout": 5
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/stop.py --chat || true",
						"timeout": 5
					}
				]
			}
		],
		"SubagentStop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/subagent_stop.py || true",
						"timeout": 5
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": ".claude/statusline/statusline.sh",
		"padding": 0
	}
}
