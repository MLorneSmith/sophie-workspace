check_local_status() {
  local feature="$1"

  echo "📁 Local Files"
  echo "--------------"

  # Specification status
  if [ -f ".claude/specs/$feature.md" ]; then
    echo "✅ Specification exists"

    # Extract metadata
    SPEC_STATUS=$(grep '^status:' ".claude/specs/$feature.md" | cut -d: -f2- | xargs)
    SPEC_CREATED=$(grep '^created:' ".claude/specs/$feature.md" | cut -d: -f2- | xargs)

    echo "   Status: ${SPEC_STATUS:-draft}"
    echo "   Created: ${SPEC_CREATED:-unknown}"
  else
    echo "❌ No specification"
    echo "   Run: /feature:spec $feature"
  fi

  # Implementation plan status
  if [ -f ".claude/implementations/$feature/plan.md" ]; then
    echo "✅ Implementation plan exists"

    # Extract progress
    PLAN_PROGRESS=$(grep '^progress:' ".claude/implementations/$feature/plan.md" | cut -d: -f2- | xargs)
    echo "   Progress: ${PLAN_PROGRESS:-0}%"

    # GitHub sync status
    GITHUB_URL=$(grep '^github:' ".claude/implementations/$feature/plan.md" | cut -d: -f2- | xargs)
    if [ -n "$GITHUB_URL" ] && [[ "$GITHUB_URL" != *"Will be"* ]]; then
      echo "   GitHub: $GITHUB_URL"
    else
      echo "   GitHub: Not synced"
    fi
  else
    echo "❌ No implementation plan"
    echo "   Run: /feature:plan $feature"
  fi
}

check_local_status "$FEATURE_NAME"
