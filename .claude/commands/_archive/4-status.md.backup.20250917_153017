```bash
query_github_status() {
  local feature="$1"

  if [ "$GH_AVAILABLE" != true ] || [ ! -f ".claude/implementations/$feature/github-mapping.md" ]; then
    return
  fi

  echo ""
  echo "🐙 GitHub Status"
  echo "----------------"

  # Extract feature issue number
  FEATURE_ISSUE=$(grep '^**Feature**:' ".claude/implementations/$feature/github-mapping.md" | \
    sed 's/.*#\([0-9]*\).*/\1/')

  if [ -n "$FEATURE_ISSUE" ]; then
    # Get feature issue state
    FEATURE_DATA=$(gh issue view "$FEATURE_ISSUE" --json state,title 2>/dev/null)

    if [ -n "$FEATURE_DATA" ]; then
      FEATURE_STATE=$(echo "$FEATURE_DATA" | jq -r '.state')
      FEATURE_TITLE=$(echo "$FEATURE_DATA" | jq -r '.title')

      echo "Feature #$FEATURE_ISSUE: $FEATURE_STATE"
      echo "Title: $FEATURE_TITLE"

      # Process task issues
      process_task_issues "$feature"
    fi
  fi
}

process_task_issues() {
  local feature="$1"

  OPEN_TASKS=0
  CLOSED_TASKS=0
  IN_PROGRESS=0

  # Process each task
  TASK_NUMBERS=$(grep '^- #' ".claude/implementations/$feature/github-mapping.md" | \
    sed 's/^- #\([0-9]*\).*/\1/')

  for task_num in $TASK_NUMBERS; do
    TASK_DATA=$(gh issue view "$task_num" --json state,labels 2>/dev/null)

    if [ -n "$TASK_DATA" ]; then
      TASK_STATE=$(echo "$TASK_DATA" | jq -r '.state')
      LABELS=$(echo "$TASK_DATA" | jq -r '.labels[].name' | tr '\n' ' ')

      case "$TASK_STATE" in
        OPEN)
          if [[ "$LABELS" =~ "in-progress" ]]; then
            ((IN_PROGRESS++))
          else
            ((OPEN_TASKS++))
          fi
          ;;
        CLOSED)
          ((CLOSED_TASKS++))
          ;;
      esac
    fi
  done

  # Calculate and display metrics
  display_progress_metrics $OPEN_TASKS $IN_PROGRESS $CLOSED_TASKS
}

display_progress_metrics() {
  local open=$1
  local in_progress=$2
  local closed=$3

  TOTAL_TASKS=$((open + in_progress + closed))

  if [ $TOTAL_TASKS -gt 0 ]; then
    PROGRESS=$(calculate_progress $closed $TOTAL_TASKS)

    echo ""
    echo "📊 Progress: $PROGRESS% ($closed/$TOTAL_TASKS)"
    echo "   ✅ Completed: $closed"
    echo "   🔄 In Progress: $in_progress"
    echo "   📋 Open: $open"

    # Show burndown
    if [ $closed -gt 0 ]; then
      VELOCITY=$((closed * 100 / TOTAL_TASKS))
      echo "   📈 Velocity: ${VELOCITY}% completion rate"
    fi
  fi
}

query_github_status "$FEATURE_NAME"
