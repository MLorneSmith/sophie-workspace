## 6. Time Estimates and Summary
<summary>
### Calculate time estimates and generate summary
```bash
calculate_time_estimates() {
  local feature="$1"

  if [ -f ".claude/implementations/$feature/plan.md" ]; then
    echo ""
    echo "⏱️ Time Estimates"
    echo "-----------------"

    # Extract estimates
    TOTAL_EFFORT=$(grep 'Estimated total effort:' ".claude/implementations/$feature/plan.md" | \
      tail -1 | cut -d: -f2- | xargs)

    if [ -n "$TOTAL_EFFORT" ]; then
      echo "Total effort: $TOTAL_EFFORT"

      # Calculate remaining
      if [ -n "$PROGRESS" ]; then
        REMAINING=$((100 - PROGRESS))
        echo "Remaining: ~${REMAINING}% of effort"
      fi
    fi

    # Show velocity if available
    if [ "$CLOSED_TASKS" -gt 0 ] && [ -n "$TOTAL_EFFORT" ]; then
      echo "Average per task: $((${TOTAL_EFFORT%h*} / TOTAL_TASKS))h"
    fi
  fi
}

generate_summary() {
  local feature="$1"

  echo ""
  echo "📋 Summary"
  echo "----------"

  # Determine overall status
  determine_status() {
    if [ "$SPEC_EXISTS" = false ]; then
      STATUS="Not started"
      NEXT_ACTION="/feature:spec $feature"
    elif [ "$PLAN_EXISTS" = false ]; then
      STATUS="Specification ready"
      NEXT_ACTION="/feature:plan $feature"
    elif [ $TASK_COUNT -eq 0 ]; then
      STATUS="Planning complete"
      NEXT_ACTION="/feature:decompose $feature"
    elif [ ! -f ".claude/implementations/$feature/github-mapping.md" ]; then
      STATUS="Ready for GitHub"
      NEXT_ACTION="/feature:sync $feature"
    elif [ -n "$PROGRESS" ]; then
      if [ $PROGRESS -eq 100 ]; then
        STATUS="✅ Complete!"
        NEXT_ACTION="Review and close"
      else
        STATUS="🚧 In Progress ($PROGRESS%)"
        NEXT_ACTION="Continue implementation"
      fi
    else
      STATUS="Ready to implement"
      NEXT_ACTION="Start first task"
    fi
  }

  determine_status
  echo "Status: $STATUS"
  echo "Next: $NEXT_ACTION"

  # Quick actions menu
  generate_quick_actions "$STATUS" "$feature"
}

generate_quick_actions() {
  local status="$1"
  local feature="$2"

  echo ""
  echo "🚀 Quick Actions"
  echo "----------------"

  # Context-specific actions
  case "$status" in
    "Not started")
      echo "• Create spec: /feature:spec $feature"
      echo "• View examples: ls .claude/specs/*.md | head -3"
      ;;
    "Specification ready")
      echo "• Create plan: /feature:plan $feature"
      echo "• Review spec: cat .claude/specs/$feature.md"
      ;;
    "Planning complete")
      echo "• Decompose: /feature:decompose $feature"
      echo "• Review plan: cat .claude/implementations/$feature/plan.md"
      ;;
    "Ready for GitHub")
      echo "• Sync: /feature:sync $feature"
      echo "• Review tasks: ls .claude/implementations/$feature/*.md"
      ;;
    *"Progress"*)
      if [ -n "$FEATURE_ISSUE" ]; then
        echo "• View on GitHub: gh issue view $FEATURE_ISSUE --web"
        echo "• View tasks: gh issue list --label feature:$feature"
      fi

      # Find next task
      for task_num in $TASK_NUMBERS; do
        STATE=$(gh issue view "$task_num" --json state -q '.state' 2>/dev/null)
        if [ "$STATE" = "OPEN" ]; then
          echo "• Start task: /do-task $task_num"
          break
        fi
      done
      ;;
  esac

  # Always available
  echo ""
  echo "• Refresh: /feature:status $feature"
  echo "• List features: ls .claude/specs/"
  echo "• Analyze parallelization: /feature:analyze $feature"
}

calculate_time_estimates "$FEATURE_NAME"
generate_summary "$FEATURE_NAME"
