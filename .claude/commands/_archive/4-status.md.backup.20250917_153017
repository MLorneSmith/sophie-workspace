       GH_AVAILABLE=true
       GH_REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)

       # Verify authentication
       if ! gh auth status &>/dev/null; then
         echo "⚠️ GitHub CLI not authenticated"
