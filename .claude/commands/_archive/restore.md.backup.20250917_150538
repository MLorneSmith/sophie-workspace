## Phase 1: Execute Pre-Restore Safety Protocol

### Validate System Prerequisites
```bash
# Verify git repository integrity
validate_git_integrity() {
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "❌ Not in a git repository"
    exit 1
  fi

  if [ -f ".git/MERGE_HEAD" ]; then
    echo "❌ Repository in merge state - resolve conflicts first"
    echo "   Run: git merge --abort OR resolve and commit"
    exit 1
  fi

  if [ -f ".git/rebase-apply" ] || [ -f ".git/rebase-merge" ]; then
    echo "❌ Repository in rebase state - complete or abort first"
    echo "   Run: git rebase --abort OR git rebase --continue"
    exit 1
  fi
}

validate_git_integrity
```

### Create Comprehensive Backup Strategy

```bash
# Check for uncommitted changes that need backup
if [ -n "$(git status --porcelain)" ]; then
  echo "⚠️ Found uncommitted changes - creating safety backup..."

  # Create timestamped backup
  backup_time=$(date +"%Y-%m-%d_%H:%M:%S")
  git stash push -m "claude-restore-backup: $backup_time" --include-untracked

  if [ $? -eq 0 ]; then
    echo "✅ Current changes backed up as: stash@{0}"
    echo "   Message: claude-restore-backup: $backup_time"
    backup_created=true
    # Adjust target reference due to new stash
    if [[ "$target_ref" =~ stash@\{([0-9]+)\} ]]; then
      new_index=$((${BASH_REMATCH[1]} + 1))
      target_ref="stash@{$new_index}"
      echo "📍 Adjusted target to: $target_ref"
    fi
  else
    echo "❌ Failed to create backup - aborting restore"
    exit 1
  fi
else
  echo "ℹ️ Working directory is clean - no backup needed"
  backup_created=false
fi
```

## Phase 2: Execute Checkpoint Application Protocol

### Analyze Checkpoint Content
```bash
# Perform detailed checkpoint analysis
analyze_checkpoint_impact() {
  echo "🔍 Analyzing checkpoint impact..."

  # Show detailed diff statistics
  git stash show "$target_ref" --numstat | head -20

  # Check for potential conflicts
  if [ -n "$(git status --porcelain)" ]; then
    echo "⚠️ Potential conflicts detected with current changes"
    git diff --name-only | while read file; do
      if git stash show "$target_ref" --name-only | grep -q "^$file$"; then
        echo "   ⚠️ Conflict: $file (modified in both)"
      fi
    done
  fi
}

analyze_checkpoint_impact
```

