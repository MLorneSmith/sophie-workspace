{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "900000",
    "BASH_MAX_TIMEOUT_MS": "1800000"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)",
      "mcp__exa__exa_search",
      "Bash(pnpm --filter admin test:coverage)",
      "Bash(.claude/scripts/codecheck-direct.sh:*)",
      "Bash(node:*)",
      "Bash(source:*)",
      "Bash(claude-main)",
      "mcp__docs-mcp__search_docs",
      "mcp__code-reasoning__code-reasoning",
      "mcp__perplexity-ask__perplexity_ask",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "Read(//tmp/**)",
      "Bash(find:*)"
    ],
    "deny": [],
    "ask": [],
    "additionalDirectories": [
      "/home/msmith"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "exa",
    "perplexity-ask",
    "context7",
    "postgres",
    "code-reasoning",
    "newrelic",
    "docs-mcp"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/supabase-directory-guard.sh"
          }
        ]
      }
    ]
  }
}