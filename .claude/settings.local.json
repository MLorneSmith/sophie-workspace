{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "900000",
    "BASH_MAX_TIMEOUT_MS": "1800000"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)",
      "mcp__exa__exa_search",
      "Bash(pnpm --filter admin test:coverage)",
      "Bash(.claude/scripts/codecheck-direct.sh:*)"
    ],
    "deny": [],
    "ask": [],
    "additionalDirectories": [
      "/home/msmith"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "exa",
    "perplexity-ask",
    "supabase",
    "context7",
    "cloudflare-observability",
    "cloudflare-bindings",
    "cloudflare-playwright",
    "postgres",
    "browser-tools",
    "code-reasoning",
    "github",
    "newrelic"
  ]
}