# Add these variables to your .env.local file for local development

# Billing Configuration (Required)
NEXT_PUBLIC_BILLING_PROVIDER=stripe  # Options: stripe, paddle, lemon-squeezy

# Cloudflare Turnstile Configuration
# Get your production keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_CAPTCHA_SITE_KEY=your_production_sitekey_here
CAPTCHA_SECRET_TOKEN=your_production_secret_here

# For CI/CD and testing environments:
# The application automatically uses Cloudflare's official test keys when:
# - NODE_ENV=test
# - CI=true
# - PLAYWRIGHT_TEST=true
#
# Test sitekey (automatic): 1x00000000000000000000AA
# Test secret (automatic): 1x0000000000000000000000000000000AA
# These test keys always pass validation and work on any domain

# New Relic Configuration
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=SlideHeroes Web - Local
NEW_RELIC_LOG_LEVEL=info

# Optional: Disable New Relic in certain environments
# NEW_RELIC_ENABLED=false