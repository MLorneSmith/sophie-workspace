# Add these variables to your .env.local file for local development

# Authentication Configuration
NEXT_PUBLIC_AUTH_PASSWORD=true  # Enable email/password authentication
NEXT_PUBLIC_AUTH_MAGIC_LINK=false  # Disable magic link authentication

# Billing Configuration (Required)
NEXT_PUBLIC_BILLING_PROVIDER=stripe  # Options: stripe, paddle, lemon-squeezy

# Cloudflare Turnstile Configuration
# Get your production keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_CAPTCHA_SITE_KEY=your_production_sitekey_here
CAPTCHA_SECRET_TOKEN=your_production_secret_here

# For CI/CD and testing environments:
# The application automatically uses Cloudflare's official test keys when:
# - NODE_ENV=test
# - CI=true
# - PLAYWRIGHT_TEST=true
# - VERCEL_ENV=development (automatically set by Vercel for dev deployments)
# - VERCEL_ENV=preview (automatically set by Vercel for preview deployments)
#
# Test sitekey (automatic): 1x00000000000000000000AA
# Test secret (automatic): 1x0000000000000000000000000000000AA
# These test keys always pass validation and work on any domain
#
# Note: VERCEL_ENV is automatically set by Vercel and cannot be overridden

# New Relic Configuration
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=SlideHeroes Web - Local
NEW_RELIC_LOG_LEVEL=info

# Optional: Disable New Relic in certain environments
# NEW_RELIC_ENABLED=false

# Alpha Workflow - E2B Sandbox Configuration
# ANTHROPIC_API_KEY is the preferred authentication method for Claude CLI
# in E2B sandboxes (simpler and more reliable than OAuth for automated systems).
# Get your API key from: https://console.anthropic.com/
# See bug fix #1449 for details on why API key auth is preferred.
ANTHROPIC_API_KEY=sk-ant-...

# Supabase CLI Authentication for Alpha Orchestrator
# Required for pushing database migrations to the sandbox database.
# Get your access token from: https://supabase.com/dashboard/account/tokens
# See bug fix #1506 for details on why this is needed.
# Without this token, database migrations created by features won't be applied.
SUPABASE_ACCESS_TOKEN=sbp_...

# PostHog Analytics (EU)
# Get your project API key from: https://eu.posthog.com/settings/project
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
# Use reverse proxy to bypass ad blockers (must match rewrites in next.config.mjs)
NEXT_PUBLIC_POSTHOG_INGESTION_URL=http://localhost:3000/ingest

# PostHog Source Maps (for production error de-minification)
# Required for @posthog/nextjs-config to upload source maps during builds.
# Get your Personal API key from: https://eu.posthog.com/settings/user-api-keys
# Get your Environment ID from: https://eu.posthog.com/settings/environment-variables
# Note: These are only used during production builds (CI/CD).
# Source maps are automatically deleted from builds after upload (security best practice).
POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key
POSTHOG_ENV_ID=your_environment_id

# Alpha Workflow - Sandbox Install Configuration (Bug fix #1924)
# Optional settings to tune pnpm install behavior for E2B sandboxes.
# These are typically not needed - defaults work well for most cases.
#
# Install timeout in milliseconds (default: 1200000 = 20 minutes)
# Increase this if install times out on slow networks or large dependencies.
# ALPHA_SANDBOX_INSTALL_TIMEOUT_MS=1200000
#
# Maximum retry attempts for failed installs (default: 3)
# Set to 0 to disable retries. Retries use exponential backoff (3s, 9s, 27s).
# ALPHA_SANDBOX_INSTALL_MAX_RETRIES=3

# Loops.so - Transactional Email & Event Automation
# Get your API key from: https://app.loops.so/settings?page=api
# Used for sending transactional emails and tracking user events.
# Server-side only - never exposed to client.
LOOPS_API_KEY=your_loops_api_key_here