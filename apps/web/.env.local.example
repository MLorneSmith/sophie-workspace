# Add these variables to your .env.local file for local development

# Billing Configuration (Required)
NEXT_PUBLIC_BILLING_PROVIDER=stripe  # Options: stripe, paddle, lemon-squeezy

# New Relic Configuration
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=SlideHeroes Web - Local
NEW_RELIC_LOG_LEVEL=info

# Optional: Disable New Relic in certain environments
# NEW_RELIC_ENABLED=false