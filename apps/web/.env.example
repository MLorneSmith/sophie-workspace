
# Netrows B2B data API
NETROWS_API_KEY=

# Mastra AI framework
MASTRA_PG_CONNECTION_STRING=
MASTRA_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENAI_API_KEY=

# Bifrost Gateway (self-hosted AI gateway with Cloudflare Access)
BIFROST_GATEWAY_URL=
BIFROST_CF_ACCESS_CLIENT_ID=
BIFROST_CF_ACCESS_CLIENT_SECRET=

# Bifrost Virtual Keys (create in Bifrost dashboard)
BIFROST_VK_WORKFLOW_RESEARCH=
BIFROST_VK_WORKFLOW_STORYBOARD=
BIFROST_VK_CANVAS_QUALITY=
BIFROST_VK_CANVAS_SUGGESTIONS=
BIFROST_VK_CANVAS_IDEAS=

# Bifrost Model Configuration (provider/model format, must match VK allowed_models)
BIFROST_MODEL_WORKFLOW_RESEARCH=openai/gpt-5
BIFROST_MODEL_WORKFLOW_STORYBOARD=openai/gpt-5
BIFROST_MODEL_CANVAS_QUALITY=openai/gpt-5
BIFROST_MODEL_CANVAS_SUGGESTIONS=openai/gpt-5
BIFROST_MODEL_CANVAS_IDEAS=openai/gpt-5
