/*
* shadcn-ui.css
*
* Updated for Tailwind CSS v4 compatibility
* Refer to https://ui.shadcn.com/docs/tailwind-v4 for latest guidelines
 */

:root {
	--font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
		Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
	--font-heading: var(--font-sans);

	/* shadcn CSS Variables - Hex format for Tailwind v4 compatibility */
	--background: #ffffff; /* white */
	--foreground: #262626; /* dark gray for WCAG AA compliance - 15.1:1 contrast */

	--card: #ffffff; /* white */
	--card-foreground: #262626; /* dark gray for WCAG AA compliance - 15.1:1 contrast */

	--popover: #ffffff; /* white */
	--popover-foreground: #262626; /* dark gray for WCAG AA compliance - 15.1:1 contrast */

	--primary: #262626; /* dark gray for WCAG AA compliance on white - 15.1:1 contrast */
	--primary-foreground: #ffffff; /* white */

	--secondary: #fafafa; /* very light gray */
	--secondary-foreground: #262626; /* dark gray for contrast - 15.1:1 */

	--muted: #f7f7f7; /* light gray background */
	--muted-foreground: #525252; /* darker gray - 7.8:1 contrast on white */

	--accent: #fafafa; /* very light gray */
	--accent-foreground: #262626; /* dark gray for contrast - 15.1:1 */

	--destructive: #dc2626; /* red-600 */
	--destructive-foreground: #ffffff; /* white */

	--border: #e5e5e5; /* gray-200 */
	--input: #e5e5e5; /* gray-200 */
	--ring: #404040; /* dark gray */

	--radius: 0.5rem;

	--chart-1: 26 90% 61%; /* orange-400 */
	--chart-2: 172 66% 50%; /* teal-400 */
	--chart-3: 142 71% 45%; /* green-500 */
	--chart-4: 48 96% 64%; /* yellow-300 */
	--chart-5: 31 97% 83%; /* orange-200 */

	--sidebar-background: 0 0% 98%; /* gray-50 */
	--sidebar-foreground: 0 0% 32%; /* gray-600 */
	--sidebar-primary: 0 0% 20%; /* dark gray */
	--sidebar-primary-foreground: 0 0% 100%; /* white */
	--sidebar-accent: 0 0% 96%; /* gray-100 */
	--sidebar-accent-foreground: 0 0% 20%; /* dark gray */
	--sidebar-border: var(--border);
	--sidebar-ring: 217 91% 60%; /* blue-500 */
}

.dark {
	--background: 0 0% 4%; /* very dark gray */
	--foreground: 0 0% 98%; /* off-white */

	--card: 0 0% 4%; /* very dark gray */
	--card-foreground: 0 0% 98%; /* off-white */

	--popover: 0 0% 4%; /* very dark gray */
	--popover-foreground: 0 0% 98%; /* off-white */

	--primary: 0 0% 98%; /* off-white */
	--primary-foreground: 0 0% 4%; /* very dark gray */

	--secondary: 0 0% 15%; /* dark gray */
	--secondary-foreground: 0 0% 98%; /* off-white */

	--muted: 0 0% 15%; /* dark gray */
	--muted-foreground: 0 0% 64%; /* medium gray */

	--accent: 0 0% 15%; /* dark gray */
	--accent-foreground: 0 0% 98%; /* off-white */

	--destructive: 0 72% 51%; /* red-600 */
	--destructive-foreground: 0 0% 98%; /* off-white */

	--border: 0 0% 15%; /* border gray */
	--input: 0 0% 15%; /* input gray */
	--ring: 0 0% 83%; /* light gray */

	--chart-1: 221 83% 53%; /* blue-600 */
	--chart-2: 158 64% 52%; /* emerald-400 */
	--chart-3: 26 90% 61%; /* orange-400 */
	--chart-4: 271 91% 65%; /* purple-500 */
	--chart-5: 330 81% 60%; /* pink-500 */

	--sidebar-background: 0 0% 10%; /* very dark gray */
	--sidebar-foreground: 0 0% 96%; /* off-white */
	--sidebar-primary: 217 91% 60%; /* blue-500 */
	--sidebar-primary-foreground: 0 0% 100%; /* white */
	--sidebar-accent: 0 0% 15%; /* dark gray */
	--sidebar-accent-foreground: 0 0% 96%; /* off-white */
	--sidebar-border: var(--border);
	--sidebar-ring: 217 91% 60%; /* blue-500 */
}

/* Tailwind v4 Theme Mapping - Following official shadcn/ui v4 documentation */
@theme inline {
	/* Map CSS variables to Tailwind color utilities with hsl() wrapper */
	--color-background: hsl(var(--background));
	--color-foreground: hsl(var(--foreground));
	--color-card: hsl(var(--card));
	--color-card-foreground: hsl(var(--card-foreground));
	--color-popover: hsl(var(--popover));
	--color-popover-foreground: hsl(var(--popover-foreground));
	--color-primary: hsl(var(--primary));
	--color-primary-foreground: hsl(var(--primary-foreground));
	--color-secondary: hsl(var(--secondary));
	--color-secondary-foreground: hsl(var(--secondary-foreground));
	--color-muted: hsl(var(--muted));
	--color-muted-foreground: hsl(var(--muted-foreground));
	--color-accent: hsl(var(--accent));
	--color-accent-foreground: hsl(var(--accent-foreground));
	--color-destructive: hsl(var(--destructive));
	--color-destructive-foreground: hsl(var(--destructive-foreground));
	--color-border: hsl(var(--border));
	--color-input: hsl(var(--input));
	--color-ring: hsl(var(--ring));
	--color-sidebar-background: hsl(var(--sidebar-background));
	--color-sidebar-foreground: hsl(var(--sidebar-foreground));
	--color-sidebar-primary: hsl(var(--sidebar-primary));
	--color-sidebar-primary-foreground: hsl(var(--sidebar-primary-foreground));
	--color-sidebar-accent: hsl(var(--sidebar-accent));
	--color-sidebar-accent-foreground: hsl(var(--sidebar-accent-foreground));
	--color-sidebar-border: hsl(var(--sidebar-border));
	--color-sidebar-ring: hsl(var(--sidebar-ring));
}
