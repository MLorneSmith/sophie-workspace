// This patch should be applied to the sign-in action to enforce MFA for admin users

// After successful login, check if user is admin and enforce MFA
async function signInWithPassword(email: string, password: string) {
  const { data, error } = await supabase.auth.signInWithPassword({
    email,
    password,
  });

  if (error) {
    throw error;
  }

  // Check if user has super-admin role
  const userMetadata = data.user?.app_metadata;
  const isSuperAdmin = userMetadata?.role === 'super-admin';

  if (isSuperAdmin) {
    // Check current assurance level
    const { data: assuranceLevel } = await supabase.auth.mfa.getAuthenticatorAssuranceLevel();

    // If user is super-admin but doesn't have AAL2, require MFA
    if (assuranceLevel?.currentLevel !== 'aal2') {
      // Trigger MFA challenge
      const { data: factors } = await supabase.auth.mfa.listFactors();

      if (factors?.totp && factors.totp.length > 0) {
        // User has TOTP configured, redirect to MFA verification
        return {
          requiresMfa: true,
          redirectTo: '/auth/verify?next=/admin'
        };
      }
    }
  }

  return {
    requiresMfa: false,
    redirectTo: '/home'
  };
}