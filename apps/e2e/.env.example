# E2E Testing Environment Variables
# Copy this file to .env.local and fill in the values

# E2E Database Configuration
# NOTE: Port 54521 is used for WSL2 compatibility (avoiding Windows port conflicts)
E2E_SUPABASE_URL="http://localhost:54521"
E2E_SUPABASE_ANON_KEY="your-anon-key-here"
E2E_SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Database Connection
E2E_DATABASE_URL="postgresql://postgres:postgres@localhost:54522/postgres"

# Test Configuration
ENABLE_BILLING_TESTS="false"
ENABLE_TEAM_ACCOUNT_TESTS="true"
DEBUG="false"

# Web Server Configuration for E2E
PLAYWRIGHT_WEB_COMMAND="pnpm --filter=web dev:test"
PLAYWRIGHT_PAYLOAD_COMMAND="pnpm --filter=payload dev"

# Test User Credentials
# These are REQUIRED for E2E tests to run successfully
# In CI: These should be set as GitHub Secrets
# In Local: Copy to .env.local and fill with actual values

# Test user (standard user account)
E2E_TEST_USER_EMAIL="test1@slideheroes.com"
E2E_TEST_USER_PASSWORD="your-test-password-here"

# Owner user (account owner with elevated permissions)
E2E_OWNER_EMAIL="test2@slideheroes.com"
E2E_OWNER_PASSWORD="your-owner-password-here"

# Super admin user (highest level admin access with MFA)
E2E_ADMIN_EMAIL="michael@slideheroes.com"
E2E_ADMIN_PASSWORD="your-admin-password-here"

# Optional: For debugging credential issues
# Set to "true" to enable verbose credential validation logging
E2E_VERBOSE_CREDENTIALS="false"

# Stripe Test Configuration (Required for Billing E2E Tests)
# To run billing tests, set ENABLE_BILLING_TESTS="true" above and configure:
#
# STRIPE_SECRET_KEY: Your Stripe test mode secret key (starts with sk_test_)
# Get this from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_test_secret_key"

# STRIPE_WEBHOOK_SECRET: Webhook signing secret for validating webhook events
# Option 1 (Docker): Use the stripe-webhook container which auto-generates this
# Option 2 (Manual): Run `stripe listen --print-secret` locally
# Option 3 (Static): Create a webhook endpoint in Stripe Dashboard and use that secret
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"

# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: Your Stripe test mode publishable key (starts with pk_test_)
# Get this from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# Stripe Webhook Forwarding (Docker Test Environment)
# When using docker-compose.test.yml with --profile billing:
# 1. The stripe-webhook container runs `stripe listen` to forward events
# 2. The webhook signing secret is captured and stored in /stripe/webhook-secret
# 3. The app-test container reads this secret to validate incoming webhooks
#
# To start test environment with billing:
#   docker-compose -f docker-compose.test.yml --profile billing up -d
#
# To run billing E2E tests:
#   ENABLE_BILLING_TESTS=true pnpm --filter e2e test -- --grep "billing"