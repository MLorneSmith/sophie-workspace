# E2E Testing Environment Variables
# Copy this file to .env.local and fill in the values

# E2E Database Configuration
E2E_SUPABASE_URL="http://localhost:55321"
E2E_SUPABASE_ANON_KEY="your-anon-key-here"
E2E_SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Database Connection
E2E_DATABASE_URL="postgresql://postgres:postgres@localhost:55322/postgres"

# Test Configuration
ENABLE_BILLING_TESTS="false"
ENABLE_TEAM_ACCOUNT_TESTS="true"
DEBUG="false"

# Web Server Configuration for E2E
PLAYWRIGHT_WEB_COMMAND="pnpm --filter=web dev:test"
PLAYWRIGHT_PAYLOAD_COMMAND="pnpm --filter=payload dev"

# Test User Credentials
E2E_TEST_USER_EMAIL="test@example.com"
E2E_TEST_USER_PASSWORD="testpassword123"
E2E_OWNER_EMAIL="owner@example.com"
E2E_OWNER_PASSWORD="testpassword123"
E2E_ADMIN_EMAIL="admin@example.com"
E2E_ADMIN_PASSWORD="testpassword123"