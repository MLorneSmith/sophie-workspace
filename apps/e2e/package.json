		"a11y:test:ci": "playwright test tests/accessibility/accessibility-hybrid-simple.spec.ts --project=chromium --reporter=junit,html",
		"a11y:test:quick": "playwright test tests/accessibility/accessibility-hybrid-simple.spec.ts --project=chromium --reporter=list",
		"test:shard1": "playwright test tests/accessibility/accessibility-hybrid.spec.ts",
		"test:shard2": "playwright test tests/authentication/auth.spec.ts",
		"test:shard3": "playwright test tests/admin/admin.spec.ts",
		"test:shard4": "playwright test tests/smoke/smoke.spec.ts",
		"test:shard5": "playwright test tests/accessibility/accessibility-hybrid-simple.spec.ts",
		"test:shard6": "playwright test tests/team-accounts/team-accounts.spec.ts",
		"test:shard7": "playwright test tests/account/account.spec.ts tests/invitations/invitations.spec.ts",
		"test:shard8": "playwright test tests/authentication/password-reset.spec.ts tests/healthcheck.spec.ts tests/team-accounts/team-invitation-mfa.spec.ts",
		"test:shard9": "playwright test tests/team-billing/team-billing.spec.ts tests/user-billing/user-billing.spec.ts"
