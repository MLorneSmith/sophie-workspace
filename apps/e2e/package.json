{
	"name": "web-e2e",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"report": "playwright show-report",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:continue": "playwright test --max-failures=0",
		"test:fail-fast": "FAIL_FAST=true playwright test",
		"test:smoke": "playwright test --grep @smoke --project=chromium --retries=2 --max-failures=0 --config=playwright.smoke.config.ts",
		"test:integration": "playwright test --grep @integration --project=chromium --retries=1 --max-failures=0",
		"a11y:test": "playwright test tests/accessibility/accessibility-hybrid-simple.spec.ts --project=chromium --reporter=html,list",
		"a11y:test:ci": "playwright test tests/accessibility/accessibility-hybrid-simple.spec.ts --project=chromium --reporter=junit,html",
		"a11y:test:quick": "playwright test tests/accessibility/accessibility-hybrid-simple.spec.ts --project=chromium --reporter=list",
		"test:shard1": "playwright test tests/smoke/smoke.spec.ts --config=playwright.smoke.config.ts",
		"test:shard2": "playwright test tests/authentication/auth-simple.spec.ts tests/authentication/auth.spec.ts tests/authentication/password-reset.spec.ts --config=playwright.auth.config.ts",
		"test:shard3": "playwright test tests/account/account.spec.ts tests/account/account-simple.spec.ts tests/team-accounts/team-accounts.spec.ts tests/team-accounts/team-invitation-mfa.spec.ts",
		"test:shard4": "playwright test tests/admin/admin.spec.ts tests/invitations/invitations.spec.ts",
		"test:shard5": "playwright test tests/accessibility/accessibility-hybrid.spec.ts tests/accessibility/accessibility-hybrid-simple.spec.ts",
		"test:shard6": "playwright test tests/test-configuration-verification.spec.ts tests/healthcheck.spec.ts",
		"test:shard7": "playwright test tests/payload/payload-auth.spec.ts tests/payload/payload-collections.spec.ts tests/payload/payload-database.spec.ts",
		"test:shard8": "echo 'Shard 8 reserved for future tests'",
		"test:shard9": "playwright test tests/user-billing/user-billing.spec.ts --config=playwright.billing.config.ts",
		"test:shard10": "playwright test tests/team-billing/team-billing.spec.ts --config=playwright.billing.config.ts",
		"test:group:smoke": "playwright test tests/smoke/smoke.spec.ts --config=playwright.smoke.config.ts",
		"test:group:auth": "playwright test tests/authentication/auth-simple.spec.ts tests/authentication/auth.spec.ts tests/authentication/password-reset.spec.ts --config=playwright.auth.config.ts",
		"test:group:accounts": "playwright test tests/account/account.spec.ts tests/account/account-simple.spec.ts tests/team-accounts/team-accounts.spec.ts tests/team-accounts/team-invitation-mfa.spec.ts",
		"test:group:admin": "playwright test tests/admin/admin.spec.ts tests/invitations/invitations.spec.ts",
		"test:group:user-billing": "playwright test tests/user-billing/user-billing.spec.ts --config=playwright.billing.config.ts",
		"test:group:team-billing": "playwright test tests/team-billing/team-billing.spec.ts --config=playwright.billing.config.ts",
		"test:billing": "playwright test tests/user-billing tests/team-billing --config=playwright.billing.config.ts",
		"test:group:accessibility": "playwright test tests/accessibility/accessibility-hybrid.spec.ts tests/accessibility/accessibility-hybrid-simple.spec.ts",
		"test:group:config": "playwright test tests/test-configuration-verification.spec.ts tests/healthcheck.spec.ts",
		"test:group:payload": "playwright test tests/payload/payload-auth.spec.ts tests/payload/payload-collections.spec.ts tests/payload/payload-database.spec.ts",
		"test:debug": "playwright test tests/debug/ --project=chromium",
		"test:debug:ui": "playwright test tests/debug/ --ui"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@playwright/test": "^1.55.0",
		"@supabase/supabase-js": "2.57.2",
		"@types/node": "^24.3.1",
		"chrome-launcher": "^1.2.0",
		"dotenv": "17.2.2",
		"lighthouse": "^12.8.1",
		"node-html-parser": "^7.0.1",
		"totp-generator": "^1.0.0"
	},
	"dependencies": {
		"@hookform/resolvers": "5.2.1",
		"@kit/shared": "workspace:*"
	}
}
