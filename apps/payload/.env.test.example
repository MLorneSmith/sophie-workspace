# TEST ENVIRONMENT VARIABLES
NODE_ENV=test

# Database URL for E2E tests (unified architecture)
# Note: sslmode=disable required for local Supabase (self-signed certs)
DATABASE_URL=postgresql://postgres:postgres@localhost:54522/postgres?sslmode=disable
DATABASE_URI=postgresql://postgres:postgres@localhost:54522/postgres?sslmode=disable

# Payload configuration
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3021
PAYLOAD_SECRET=test_payload_secret_for_e2e_testing

# Seeding configuration
SEED_USER_PASSWORD=aiesec1992
# Optional: password for the sophie-api service account user
# If not set, the sophie-api user will be skipped during seeding (257/258 records)
# SEED_SOPHIE_API_PASSWORD=your_sophie_api_password_here

# Supabase configuration for E2E tests (unified architecture)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54521
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Email configuration for tests
EMAIL_SENDER=test@makerkit.dev
EMAIL_PORT=54525
EMAIL_HOST=localhost
EMAIL_TLS=false
EMAIL_USER=user
EMAIL_PASSWORD=password

# Required for app to start
NEXT_PUBLIC_BILLING_PROVIDER=stripe

# R2 Storage Configuration
# ⚠️ IMPORTANT: Replace with your own Cloudflare R2 credentials
# These are used for local seeding - files must be pre-uploaded to your R2 buckets
# Get these from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_MEDIA_BUCKET=media
R2_DOWNLOADS_BUCKET=downloads
R2_REGION=auto

# Custom domain URLs for R2 buckets (publicly accessible)
# Update these to match your R2 bucket custom domains
PAYLOAD_PUBLIC_MEDIA_BASE_URL=https://media.yourdomain.com
PAYLOAD_PUBLIC_DOWNLOADS_BASE_URL=https://downloads.yourdomain.com
