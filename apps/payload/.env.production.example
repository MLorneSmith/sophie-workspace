# Production Environment Variables for Payload CLI Migration
#
# Copy this file to .env.production and fill in the values.
# NEVER commit .env.production - it contains secrets!
#
# For E2B sandboxes, the orchestrator provides these values automatically
# via getAllEnvVars().

# =============================================================================
# Database Configuration (REQUIRED)
# =============================================================================
# Provided via environment variable - do not hardcode
# Get from Supabase Dashboard > Project Settings > Database
DATABASE_URI=postgresql://postgres.<project-ref>:<password>@<host>:<port>/postgres?sslmode=require

# =============================================================================
# Payload Configuration (REQUIRED)
# =============================================================================
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=<generate-a-secure-random-string>

# =============================================================================
# Production Settings
# =============================================================================
NODE_ENV=production
PAYLOAD_MIGRATION_MODE=production
PAYLOAD_ENABLE_SSL=true

# Server Configuration
PAYLOAD_PUBLIC_SERVER_URL=https://payload.slideheroes.com

# =============================================================================
# Logging Configuration (Optional)
# =============================================================================
LOG_LEVEL=info
PAYLOAD_DEBUG=false

# =============================================================================
# Database Health Monitoring (Optional)
# =============================================================================
ENABLE_DB_HEALTH_MONITORING=true
DB_HEALTH_CHECK_INTERVAL=30000

# =============================================================================
# R2 Storage Configuration (REQUIRED for Production)
# =============================================================================
# Get from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCOUNT_ID=<your-cloudflare-account-id>

# R2 Buckets
R2_MEDIA_BUCKET=media
R2_DOWNLOADS_BUCKET=downloads

# =============================================================================
# Public URLs (Optional)
# =============================================================================
PAYLOAD_PUBLIC_MEDIA_BASE_URL=https://media.slideheroes.com
PAYLOAD_PUBLIC_DOWNLOADS_BASE_URL=https://downloads.slideheroes.com
