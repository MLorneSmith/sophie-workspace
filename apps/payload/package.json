{
	"name": "payload",
	"version": "3.72.0",
	"description": "A blank template to get started with Payload 3.0",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"verify-config": "dotenv -e .env -- node scripts/verify-config.js",
		"verify-config:dev": "dotenv -e .env.development -- node scripts/verify-config.js",
		"verify-config:prod": "dotenv -e .env.production -- node scripts/verify-config.js",
		"build": "cross-env NODE_ENV=production NODE_OPTIONS=--no-deprecation next build --webpack",
		"dev": "cross-env PORT=3020 NODE_OPTIONS=--no-deprecation next dev",
		"dev:test": "dotenv -e .env.test -- cross-env PORT=3021 NODE_OPTIONS=--no-deprecation next dev",
		"start:test": "dotenv -e .env.test -- cross-env PORT=3021 NODE_OPTIONS=--no-deprecation next start",
		"cache:clear": "rimraf .next .turbo",
		"clean": "rimraf .next .turbo node_modules",
		"devsafe": "pnpm cache:clear && cross-env NODE_OPTIONS=--no-deprecation next dev",
		"generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
		"generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts NODE_OPTIONS=--no-deprecation payload generate:types && node scripts/sync-types.js",
		"lint": "biome lint . --write",
		"format": "biome format . --write",
		"check": "biome check . --write",
		"payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts NODE_OPTIONS=--no-deprecation payload",
		"start": "cross-env NODE_OPTIONS=--no-deprecation next start",
		"print-env": "echo PAYLOAD_SECRET=$PAYLOAD_SECRET && echo DATABASE_URI=$DATABASE_URI && echo PAYLOAD_PUBLIC_SERVER_URL=$PAYLOAD_PUBLIC_SERVER_URL",
		"clean:init-scripts": "node -e \"require('fs').rmSync('./dist', { recursive: true, force: true })\"",
		"build:init-scripts": "node -e \"require('fs').rmSync('./dist', { recursive: true, force: true })\" && pnpm exec tsc --project tsconfig.init-scripts.json --listEmittedFiles --extendedDiagnostics && xcopy src\\init-scripts\\data dist\\src\\init-scripts\\data /E /I /Y",
		"preinit:data": "pnpm run build:init-scripts",
		"init:data": "node dist/src/init-scripts/initialize-payload-data.js",
		"test": "cross-env NODE_OPTIONS='--max-old-space-size=8192' vitest",
		"test:run": "cross-env NODE_OPTIONS='--max-old-space-size=8192' vitest run",
		"test:watch": "cross-env NODE_OPTIONS='--max-old-space-size=8192' vitest watch",
		"test:coverage": "cross-env NODE_OPTIONS='--max-old-space-size=8192' vitest run --coverage",
		"seed:convert": "tsx src/seed/seed-conversion/index.ts",
		"seed:convert:dry": "tsx src/seed/seed-conversion/index.ts --dry-run",
		"seed:run": "cross-env SKIP_STORAGE_PLUGIN=true tsx src/seed/seed-engine/index.ts",
		"seed:run:remote": "cross-env SKIP_STORAGE_PLUGIN=true tsx src/seed/seed-engine/index.ts --env=production --force",
		"seed:dry": "cross-env SKIP_STORAGE_PLUGIN=true tsx src/seed/seed-engine/index.ts --dry-run",
		"seed:validate": "tsx src/seed/seed-engine/index.ts --dry-run --verbose",
		"seed:courses": "tsx src/seed/seed-engine/index.ts -c courses,course-lessons,course-quizzes",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.940.0",
		"@hookform/resolvers": "5.2.2",
		"@kit/shared": "workspace:*",
		"@markdoc/markdoc": "^0.5.4",
		"@payloadcms/db-postgres": "3.72.0",
		"@payloadcms/next": "^3.72.0",
		"@payloadcms/payload-cloud": "^3.72.0",
		"@payloadcms/plugin-nested-docs": "^3.72.0",
		"@payloadcms/richtext-lexical": "3.72.0",
		"@payloadcms/storage-s3": "^3.72.0",
		"@payloadcms/translations": "^3.72.0",
		"chalk": "^5.6.2",
		"cross-env": "^10.1.0",
		"execa": "^9.6.1",
		"graphql": "^16.12.0",
		"js-yaml": "^4.1.1",
		"next": "catalog:",
		"payload": "3.72.0",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"sharp": "0.34.5",
		"uuid": "^13.0.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/fs-extra": "^11.0.4",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.10.1",
		"@types/pg": "^8.15.6",
		"@types/react": "19.2.7",
		"@types/react-dom": "catalog:",
		"@types/yargs": "^17.0.35",
		"commander": "^14.0.2",
		"copyfiles": "^2.4.1",
		"dotenv": "17.2.3",
		"dotenv-cli": "^11.0.0",
		"fs-extra": "^11.3.2",
		"gray-matter": "^4.0.3",
		"jsdom": "^27.3.0",
		"pg": "^8.16.3",
		"pino": "^10.1.0",
		"pino-pretty": "13.1.3",
		"prettier": "^3.7.4",
		"rimraf": "^6.1.2",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"yargs": "^18.0.0"
	},
	"engines": {
		"node": "^18.20.2 || >=20.9.0",
		"pnpm": "^9 || ^10"
	}
}
