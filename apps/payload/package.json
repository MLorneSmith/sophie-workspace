{
  "name": "payload-app",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3020",
    "devsafe": "if exist .next rd /s /q .next && cross-env NODE_OPTIONS=--no-deprecation next dev -p 3020",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "fix:importmap": "tsx src/scripts/fix-importmap.ts",
    "fix:importmap:simple": "node src/scripts/fix-importmap-simple.js",
    "fix:lexical": "node src/scripts/fix-lexical-importmap.js",
    "rebuild:importmap": "node src/scripts/rebuild-importmap.js",
    "dev:fixed": "pnpm generate:importmap && pnpm dev",
    "dev:clean": "if exist .next rd /s /q .next && pnpm generate:importmap && pnpm dev",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:schema": "cross-env NODE_OPTIONS=--no-deprecation payload generate:db-schema",
    "lint": "eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "migrate:down": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:down",
    "migrate:refresh": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:refresh",
    "ci": "cross-env NODE_OPTIONS=--no-deprecation payload migrate && pnpm build",
    "seed:build": "tsc -p src/scripts/tsconfig.json",
    "seed:survey": "tsx src/scripts/seed-all.ts survey data/surveys/self-assessment.yaml",
    "seed:course": "tsx src/scripts/seed-all.ts course data/courses/lessons data/courses/quizzes",
    "seed:all": "tsx src/scripts/seed-all.ts all data/surveys/self-assessment.yaml data/courses/lessons data/courses/quizzes"
  },
  "dependencies": {
    "@kit/ui": "workspace:*",
    "@payloadcms/db-postgres": "3.30.0",
    "@payloadcms/next": "3.30.0",
    "@payloadcms/payload-cloud": "3.30.0",
    "@payloadcms/plugin-nested-docs": "3.30.0",
    "@payloadcms/richtext-lexical": "3.30.0",
    "commander": "^11.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "graphql": "^16.8.1",
    "gray-matter": "^4.0.3",
    "next": "15.2.3",
    "node-fetch": "^3.3.2",
    "payload": "3.30.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.32.6",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^22.13.11",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@types/yaml": "^1.9.7",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.23.0",
    "eslint-config-next": "15.2.3",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.5.3",
    "tailwindcss": "4.0.15",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.7.1",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
