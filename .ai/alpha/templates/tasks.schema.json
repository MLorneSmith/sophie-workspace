{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://slideheroes.com/schemas/alpha/tasks.schema.json",
	"title": "Alpha Task Decomposition",
	"description": "Schema for MAKER-compliant task decomposition in the Alpha autonomous coding workflow",
	"type": "object",
	"required": ["metadata", "tasks", "execution", "validation"],
	"properties": {
		"metadata": {
			"type": "object",
			"description": "Feature and decomposition metadata",
			"required": [
				"feature_id",
				"feature_name",
				"initiative_id",
				"spec_id",
				"created_at",
				"complexity"
			],
			"properties": {
				"feature_id": {
					"type": "string",
					"pattern": "^S\\d+\\.I\\d+\\.F\\d+$",
					"description": "Semantic feature ID (e.g., S1362.I1.F1)"
				},
				"feature_name": {
					"type": "string",
					"description": "Human-readable feature name"
				},
				"feature_slug": {
					"type": "string",
					"pattern": "^[a-z0-9-]+$",
					"description": "URL-safe feature identifier"
				},
				"initiative_id": {
					"type": "string",
					"pattern": "^S\\d+\\.I\\d+$",
					"description": "Semantic initiative ID (e.g., S1362.I1)"
				},
				"spec_id": {
					"type": "string",
					"pattern": "^S?\\d+$",
					"description": "Spec ID with optional S prefix (e.g., S1362 or 1362)"
				},
				"created_at": {
					"type": "string",
					"format": "date-time",
					"description": "ISO 8601 timestamp of decomposition"
				},
				"complexity": {
					"type": "object",
					"required": ["score", "level", "target_steps"],
					"properties": {
						"score": {
							"type": "integer",
							"minimum": 0,
							"maximum": 100,
							"description": "Complexity score from estimator"
						},
						"level": {
							"type": "string",
							"enum": ["MINIMAL", "LOW", "STANDARD", "HIGH", "MAXIMAL"],
							"description": "Granularity level based on score"
						},
						"target_steps": {
							"type": "object",
							"properties": {
								"min": { "type": "integer" },
								"max": { "type": "integer" }
							}
						},
						"pattern_matched": {
							"type": ["string", "null"],
							"description": "Decomposition pattern used, if any"
						}
					}
				},
				"requires_database": {
					"type": "boolean",
					"default": false,
					"description": "True if any task in this feature requires database access"
				},
				"database_tasks": {
					"type": "array",
					"items": { "type": "string" },
					"description": "List of task IDs that require database access (e.g., ['T3', 'T5'])"
				},
				"requires_ui": {
					"type": "boolean",
					"default": false,
					"description": "True if any task in this feature creates/modifies UI components"
				},
				"ui_tasks": {
					"type": "array",
					"items": { "type": "string" },
					"description": "List of task IDs that require UI verification (e.g., ['T4', 'T5', 'T8'])"
				},
				"required_env_vars": {
					"type": "array",
					"description": "Environment variables/credentials this feature requires at runtime",
					"items": {
						"type": "object",
						"required": ["name", "description", "source"],
						"properties": {
							"name": {
								"type": "string",
								"pattern": "^[A-Z][A-Z0-9_]*$",
								"description": "Environment variable name (e.g., CAL_OAUTH_CLIENT_ID)"
							},
							"description": {
								"type": "string",
								"description": "What this credential is used for"
							},
							"source": {
								"type": "string",
								"description": "Where to obtain this credential (URL or instructions)"
							},
							"required": {
								"type": "boolean",
								"default": true,
								"description": "If false, feature can degrade gracefully without this"
							},
							"scope": {
								"type": "string",
								"enum": ["client", "server", "both"],
								"description": "Where variable is used (affects NEXT_PUBLIC_ prefix)"
							}
						}
					}
				}
			}
		},
		"tasks": {
			"type": "array",
			"description": "All tasks including spikes. Hard maximum of 12 tasks per feature; if more are needed, split the feature in /alpha:feature-decompose.",
			"minItems": 1,
			"maxItems": 12,
			"items": {
				"$ref": "#/definitions/task"
			}
		},
		"execution": {
			"type": "object",
			"description": "Execution planning and dependency analysis",
			"required": ["groups", "critical_path", "duration"],
			"properties": {
				"groups": {
					"type": "array",
					"description": "Parallel execution groups (Group 0 = spikes)",
					"items": {
						"type": "object",
						"required": ["id", "name", "task_ids"],
						"properties": {
							"id": {
								"type": "integer",
								"description": "Group number (0 = spikes, run first)"
							},
							"name": {
								"type": "string",
								"description": "Human-readable group name"
							},
							"task_ids": {
								"type": "array",
								"items": { "type": "string" },
								"description": "Task IDs in this group (can run in parallel)"
							},
							"depends_on_groups": {
								"type": "array",
								"items": { "type": "integer" },
								"description": "Group IDs that must complete before this group starts"
							},
							"estimated_hours": {
								"type": "number",
								"description": "Total hours if run sequentially"
							},
							"parallel_hours": {
								"type": "number",
								"description": "Hours if run in parallel (max of tasks)"
							},
							"parallel_batches": {
								"type": "array",
								"description": "Batches of tasks that can safely run in parallel (no file conflicts)",
								"items": {
									"type": "object",
									"required": ["batch_id", "task_ids", "max_hours"],
									"properties": {
										"batch_id": {
											"type": "integer",
											"description": "Batch number within this group (1-based)"
										},
										"task_ids": {
											"type": "array",
											"items": { "type": "string" },
											"description": "Task IDs that can run simultaneously"
										},
										"max_hours": {
											"type": "number",
											"description": "Maximum hours (longest task in batch)"
										},
										"reason": {
											"type": "string",
											"description": "Why these tasks can run in parallel"
										}
									}
								}
							},
							"sequential_tasks": {
								"type": "array",
								"items": { "type": "string" },
								"description": "Task IDs that must run sequentially due to file conflicts"
							},
							"parallelization_analysis": {
								"type": "object",
								"description": "Analysis of task parallelizability within this group",
								"properties": {
									"total_tasks": { "type": "integer" },
									"parallelizable_count": { "type": "integer" },
									"sequential_count": { "type": "integer" },
									"file_conflicts": {
										"type": "array",
										"items": {
											"type": "object",
											"properties": {
												"task_a": { "type": "string" },
												"task_b": { "type": "string" },
												"conflicting_file": { "type": "string" }
											}
										}
									},
									"speedup_potential": { "type": "number" }
								}
							}
						}
					}
				},
				"critical_path": {
					"type": "object",
					"required": ["task_ids", "total_hours"],
					"properties": {
						"task_ids": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Ordered list of tasks on critical path"
						},
						"total_hours": {
							"type": "number",
							"description": "Total duration of critical path"
						}
					}
				},
				"duration": {
					"type": "object",
					"required": ["sequential", "parallel"],
					"properties": {
						"sequential": {
							"type": "number",
							"description": "Total hours if all tasks run sequentially"
						},
						"parallel": {
							"type": "number",
							"description": "Total hours with parallel execution"
						},
						"time_saved_percent": {
							"type": "number",
							"description": "Percentage time saved through parallelization"
						}
					}
				}
			}
		},
		"validation": {
			"type": "object",
			"description": "MAKER compliance validation results",
			"required": ["discriminator_verdict", "scores", "dependency_checks"],
			"properties": {
				"discriminator_verdict": {
					"type": "string",
					"enum": ["APPROVED", "NEEDS_REVISION", "REJECTED"],
					"description": "Overall validation result"
				},
				"scores": {
					"type": "object",
					"properties": {
						"completeness": { "type": "number", "minimum": 0, "maximum": 100 },
						"atomicity": { "type": "number", "minimum": 0, "maximum": 100 },
						"dependencies": { "type": "number", "minimum": 0, "maximum": 100 },
						"state_flow": { "type": "number", "minimum": 0, "maximum": 100 },
						"testability": { "type": "number", "minimum": 0, "maximum": 100 }
					}
				},
				"dependency_checks": {
					"type": "object",
					"properties": {
						"no_cycles": { "type": "boolean" },
						"all_documented": { "type": "boolean" },
						"spikes_first": { "type": "boolean" },
						"critical_path_valid": { "type": "boolean" }
					}
				},
				"m1_compliance": {
					"type": "number",
					"minimum": 0,
					"maximum": 100,
					"description": "Percentage of tasks that are m=1 compliant"
				}
			}
		},
		"github": {
			"type": "object",
			"description": "GitHub issue tracking (populated after issues created)",
			"properties": {
				"issues_created": {
					"type": "boolean",
					"default": false
				},
				"issue_map": {
					"type": "object",
					"description": "Map of task_id to GitHub issue number",
					"additionalProperties": {
						"type": "integer"
					}
				}
			}
		}
	},
	"definitions": {
		"task": {
			"type": "object",
			"required": [
				"id",
				"type",
				"name",
				"action",
				"status",
				"estimated_hours",
				"priority",
				"group",
				"acceptance_criterion"
			],
			"properties": {
				"id": {
					"type": "string",
					"pattern": "^(S\\d+\\.I\\d+\\.F\\d+\\.)?(S|T)\\d+$",
					"description": "Task ID: Fully qualified (S1362.I1.F1.T1) or shorthand (T1) within feature context"
				},
				"type": {
					"type": "string",
					"enum": ["spike", "task"],
					"description": "Task type"
				},
				"name": {
					"type": "string",
					"description": "Single-verb task name"
				},
				"action": {
					"type": "object",
					"required": ["verb", "target"],
					"properties": {
						"verb": {
							"type": "string",
							"enum": [
								"Create",
								"Add",
								"Update",
								"Remove",
								"Wire",
								"Extract",
								"Rename",
								"Move",
								"Configure",
								"Test",
								"Spike"
							],
							"description": "Single action verb"
						},
						"target": {
							"type": "string",
							"description": "What the action applies to"
						}
					}
				},
				"purpose": {
					"type": "string",
					"description": "Why this task exists (one sentence)"
				},
				"status": {
					"type": "string",
					"enum": [
						"draft",
						"ready",
						"in_progress",
						"blocked",
						"completed",
						"skipped"
					],
					"default": "draft"
				},
				"estimated_hours": {
					"type": "number",
					"minimum": 1,
					"maximum": 8,
					"description": "Estimated hours (2-8 for MAKER compliance)"
				},
				"priority": {
					"type": "integer",
					"minimum": 0,
					"description": "Execution priority (0 = spikes, run first)"
				},
				"group": {
					"type": "integer",
					"description": "Parallel execution group ID"
				},
				"context": {
					"type": "object",
					"description": "Minimal context needed for execution (≤750 tokens)",
					"properties": {
						"files": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Relevant existing files"
						},
						"types": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Available type definitions"
						},
						"dependencies": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Available functions/components"
						},
						"constraints": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Implementation constraints"
						},
						"patterns": {
							"type": "array",
							"items": {
								"type": "object",
								"properties": {
									"file": { "type": "string" },
									"description": { "type": "string" }
								}
							},
							"description": "Reference files with patterns to follow"
						}
					}
				},
				"acceptance_criterion": {
					"type": "string",
					"description": "Single testable condition for done state"
				},
				"verification_command": {
					"type": "string",
					"description": "Bash command to verify completion"
				},
				"outputs": {
					"type": "array",
					"description": "Expected outputs from this task",
					"items": {
						"type": "object",
						"required": ["type", "path"],
						"properties": {
							"type": {
								"type": "string",
								"enum": ["new", "modified", "deleted"]
							},
							"path": {
								"type": "string",
								"description": "File path"
							},
							"description": {
								"type": "string"
							}
						}
					}
				},
				"dependencies": {
					"type": "object",
					"properties": {
						"blocked_by": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Task IDs that must complete first"
						},
						"blocks": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Task IDs waiting on this"
						}
					}
				},
				"spike_details": {
					"type": "object",
					"description": "Additional fields for spike tasks only",
					"properties": {
						"question": {
							"type": "string",
							"description": "Specific question to answer"
						},
						"timebox_hours": {
							"type": "number",
							"minimum": 2,
							"maximum": 8,
							"description": "Maximum hours to spend"
						},
						"investigation_scope": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Areas to investigate"
						},
						"blocks_tasks": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Task IDs that cannot be estimated until spike completes"
						}
					}
				},
				"m1_checks": {
					"type": "object",
					"description": "MAKER m=1 compliance checks",
					"properties": {
						"single_verb": { "type": "boolean" },
						"no_conjunctions": { "type": "boolean" },
						"under_8_hours": { "type": "boolean" },
						"under_750_tokens": { "type": "boolean" },
						"binary_done_state": { "type": "boolean" },
						"max_3_files": { "type": "boolean" }
					}
				},
				"github_issue": {
					"type": ["integer", "null"],
					"description": "GitHub issue number (deprecated - only Spec has GitHub issue)"
				},
				"requires_database": {
					"type": "boolean",
					"default": false,
					"description": "True if task creates/modifies database schema or requires DB access (migrations, tables, RLS policies, etc.)"
				},
				"migration_name_prefix": {
					"type": "string",
					"pattern": "^\\d+_[A-Za-z0-9]+$",
					"description": "Prefix for migration filename (e.g., '1367_T3') to ensure uniqueness across parallel features"
				},
				"requires_dependency_install": {
					"type": "boolean",
					"default": false,
					"description": "True if this task adds/modifies npm dependencies (package.json changes)"
				},
				"packages_added": {
					"type": "array",
					"items": { "type": "string" },
					"description": "List of npm packages added by this task (e.g., ['@example/package', 'lodash'])"
				},
				"requires_ui": {
					"type": "boolean",
					"default": false,
					"description": "True if task creates/modifies UI components that should be visually verified"
				},
				"ui_task": {
					"type": "boolean",
					"default": false,
					"description": "Alias for requires_ui. True if task creates/modifies UI components that benefit from frontend skill invocation"
				},
				"skill_hints": {
					"type": "array",
					"items": {
						"type": "string",
						"enum": ["frontend-design", "react-best-practices"]
					},
					"description": "Suggested skills to invoke during implementation: 'frontend-design' for visual components, 'react-best-practices' for performance/patterns"
				},
				"visual_verification": {
					"$ref": "#/definitions/visual_verification",
					"description": "Configuration for visual verification using agent-browser"
				},
				"behavioral_verification": {
					"$ref": "#/definitions/behavioral_verification",
					"description": "Configuration for behavioral verification patterns that validate functional completeness"
				}
			}
		},
		"visual_verification": {
			"type": "object",
			"description": "Configuration for visual verification of UI tasks using agent-browser",
			"required": ["route"],
			"properties": {
				"enabled": {
					"type": "boolean",
					"default": true,
					"description": "Whether visual verification is enabled for this task"
				},
				"route": {
					"type": "string",
					"description": "Route to navigate to for verification (e.g., '/home/dashboard')",
					"pattern": "^/"
				},
				"wait_ms": {
					"type": "integer",
					"default": 3000,
					"minimum": 0,
					"maximum": 30000,
					"description": "Milliseconds to wait after page load before running checks"
				},
				"checks": {
					"type": "array",
					"description": "Visual checks to perform on the page",
					"items": {
						"type": "object",
						"required": ["command"],
						"properties": {
							"command": {
								"type": "string",
								"enum": [
									"is visible",
									"find role",
									"find label",
									"find text",
									"snapshot"
								],
								"description": "The type of check to perform"
							},
							"target": {
								"type": "string",
								"description": "Target element text, role name, or label to find"
							},
							"flags": {
								"type": "string",
								"description": "Additional flags to pass to the agent-browser command"
							}
						}
					}
				},
				"expected_elements": {
					"type": "array",
					"description": "List of element texts that should be visible on the page",
					"items": {
						"type": "string"
					}
				},
				"screenshot": {
					"type": "boolean",
					"default": true,
					"description": "Whether to capture a screenshot after verification"
				}
			}
		},
		"behavioral_verification": {
			"type": "object",
			"description": "Configuration for behavioral verification patterns that validate functional completeness",
			"properties": {
				"patterns": {
					"type": "array",
					"description": "List of behavioral verification patterns to apply",
					"items": {
						"type": "object",
						"required": ["type"],
						"properties": {
							"type": {
								"type": "string",
								"enum": [
									"button_handler",
									"env_var_graceful",
									"form_submission",
									"link_navigation",
									"modal_trigger"
								],
								"description": "Type of behavioral pattern to verify"
							},
							"target": {
								"type": "string",
								"description": "Target element or identifier (button text, env var name, form name)"
							},
							"expected_action": {
								"type": "string",
								"description": "Expected behavior when pattern triggers (navigate, open modal, submit)"
							},
							"file_path": {
								"type": "string",
								"description": "File path to check for pattern compliance"
							}
						}
					}
				},
				"validation_command": {
					"type": "string",
					"description": "Optional bash command for pattern validation (uses grep-based checks)"
				}
			}
		},
		"verification_pattern_types": {
			"type": "object",
			"description": "Reference definitions for behavioral verification pattern types",
			"properties": {
				"button_handler": {
					"type": "object",
					"description": "Validates that Button components have non-empty onClick handlers",
					"properties": {
						"pattern_regex": {
							"type": "string",
							"default": "Button[^>]*onClick=\\{[^}]+\\}",
							"description": "Regex pattern to match Button with onClick"
						},
						"failure_message": {
							"type": "string",
							"default": "Button lacks onClick handler - interactive elements must have handlers",
							"description": "Message when pattern fails"
						}
					}
				},
				"env_var_graceful": {
					"type": "object",
					"description": "Validates that optional env vars use warn/silent degradation, not error",
					"properties": {
						"pattern_regex": {
							"type": "string",
							"default": "console\\.warn|return null|return \\[\\]",
							"description": "Regex pattern for graceful handling"
						},
						"anti_pattern_regex": {
							"type": "string",
							"default": "console\\.error.*[A-Z_]+.*not set|throw.*[A-Z_]+.*missing",
							"description": "Regex pattern for non-graceful handling to reject"
						},
						"failure_message": {
							"type": "string",
							"default": "Env var uses error logging instead of graceful degradation",
							"description": "Message when pattern fails"
						}
					}
				},
				"form_submission": {
					"type": "object",
					"description": "Validates that form components have proper onSubmit handlers",
					"properties": {
						"pattern_regex": {
							"type": "string",
							"default": "form[^>]*onSubmit=\\{[^}]+\\}|handleSubmit\\(",
							"description": "Regex pattern to match form submission handling"
						},
						"failure_message": {
							"type": "string",
							"default": "Form lacks onSubmit handler - forms must handle submission",
							"description": "Message when pattern fails"
						}
					}
				},
				"link_navigation": {
					"type": "object",
					"description": "Validates that navigation links have proper href or onClick",
					"properties": {
						"pattern_regex": {
							"type": "string",
