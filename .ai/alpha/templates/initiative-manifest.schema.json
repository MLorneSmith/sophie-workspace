{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://slideheroes.com/schemas/alpha/initiative-manifest.schema.json",
	"title": "Alpha Initiative Manifest",
	"description": "Aggregated manifest for all tasks across all features in an initiative",
	"type": "object",
	"required": ["metadata", "features", "execution_plan", "progress"],
	"properties": {
		"metadata": {
			"type": "object",
			"description": "Initiative identification and timing",
			"required": [
				"initiative_id",
				"spec_id",
				"generated_at",
				"spec_dir",
				"init_dir"
			],
			"properties": {
				"initiative_id": {
					"type": "integer",
					"description": "GitHub issue number for the initiative"
				},
				"spec_id": {
					"type": "integer",
					"description": "GitHub issue number for the parent spec"
				},
				"initiative_name": {
					"type": "string",
					"description": "Human-readable initiative name"
				},
				"generated_at": {
					"type": "string",
					"format": "date-time",
					"description": "ISO 8601 timestamp of manifest generation"
				},
				"spec_dir": {
					"type": "string",
					"description": "Path to spec directory"
				},
				"init_dir": {
					"type": "string",
					"description": "Path to initiative directory"
				},
				"research_dir": {
					"type": "string",
					"description": "Path to research-library directory"
				}
			}
		},
		"features": {
			"type": "array",
			"description": "All features in the initiative with their tasks",
			"items": {
				"$ref": "#/definitions/feature_entry"
			}
		},
		"execution_plan": {
			"type": "object",
			"description": "Parallel execution strategy for features",
			"required": [
				"parallel_groups",
				"total_tasks",
				"total_features",
				"duration"
			],
			"properties": {
				"parallel_groups": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["group", "feature_ids", "description"],
						"properties": {
							"group": {
								"type": "integer",
								"description": "Group number (0 = first to execute)"
							},
							"feature_ids": {
								"type": "array",
								"items": { "type": "integer" },
								"description": "Feature IDs in this group (can run in parallel)"
							},
							"description": {
								"type": "string",
								"description": "Human-readable group description"
							}
						}
					}
				},
				"total_tasks": {
					"type": "integer",
					"description": "Total tasks across all features"
				},
				"total_features": {
					"type": "integer",
					"description": "Number of features in initiative"
				},
				"duration": {
					"type": "object",
					"required": ["sequential_hours", "parallel_hours"],
					"properties": {
						"sequential_hours": {
							"type": "number",
							"description": "Hours if all features run sequentially"
						},
						"parallel_hours": {
							"type": "number",
							"description": "Hours with parallel execution"
						},
						"time_saved_percent": {
							"type": "number",
							"description": "Percentage time saved via parallelization"
						}
					}
				}
			}
		},
		"progress": {
			"type": "object",
			"description": "Implementation progress tracking",
			"required": ["status", "features_completed", "features_total"],
			"properties": {
				"status": {
					"type": "string",
					"enum": ["pending", "in_progress", "completed", "failed", "partial"],
					"default": "pending"
				},
				"features_completed": {
					"type": "integer",
					"default": 0
				},
				"features_total": {
					"type": "integer"
				},
				"tasks_completed": {
					"type": "integer",
					"default": 0
				},
				"tasks_total": {
					"type": "integer"
				},
				"current_feature": {
					"type": ["integer", "null"],
					"description": "Currently executing feature ID"
				},
				"current_group": {
					"type": "integer",
					"default": 0
				},
				"started_at": {
					"type": ["string", "null"],
					"format": "date-time"
				},
				"completed_at": {
					"type": ["string", "null"],
					"format": "date-time"
				},
				"last_checkpoint": {
					"type": ["string", "null"],
					"format": "date-time"
				}
			}
		},
		"sandbox": {
			"type": "object",
			"description": "E2B sandbox information (populated during execution)",
			"properties": {
				"sandbox_id": {
					"type": ["string", "null"],
					"description": "E2B sandbox ID"
				},
				"branch_name": {
					"type": ["string", "null"],
					"description": "Git branch for implementation"
				},
				"vscode_url": {
					"type": ["string", "null"],
					"description": "VS Code Web URL for review"
				},
				"dev_server_url": {
					"type": ["string", "null"],
					"description": "Dev server URL for testing"
				},
				"created_at": {
					"type": ["string", "null"],
					"format": "date-time"
				}
			}
		}
	},
	"definitions": {
		"feature_entry": {
			"type": "object",
			"required": [
				"id",
				"title",
				"priority",
				"status",
				"tasks_file",
				"task_count",
				"parallel_hours",
				"dependencies"
			],
			"properties": {
				"id": {
					"type": "integer",
					"description": "GitHub issue number for the feature"
				},
				"title": {
					"type": "string",
					"description": "Human-readable feature name"
				},
				"slug": {
					"type": "string",
					"description": "URL-safe feature identifier"
				},
				"priority": {
					"type": "integer",
					"description": "Execution priority (lower = higher priority)"
				},
				"status": {
					"type": "string",
					"enum": [
						"pending",
						"in_progress",
						"completed",
						"failed",
						"blocked",
						"partial"
					],
					"default": "pending"
				},
				"tasks_file": {
					"type": "string",
					"description": "Relative path to tasks.json for this feature"
				},
				"feature_dir": {
					"type": "string",
					"description": "Path to feature directory"
				},
				"task_count": {
					"type": "integer",
					"description": "Number of tasks in this feature"
				},
				"tasks_completed": {
					"type": "integer",
					"default": 0
				},
				"sequential_hours": {
					"type": "number",
					"description": "Hours if tasks run sequentially"
				},
				"parallel_hours": {
					"type": "number",
					"description": "Hours with task parallelization"
				},
				"dependencies": {
					"type": "array",
					"items": { "type": "integer" },
					"description": "Feature IDs this feature depends on"
				},
				"github_issue": {
					"type": ["integer", "null"],
					"description": "GitHub issue for task tracking"
				},
				"error": {
					"type": ["string", "null"],
					"description": "Error message if failed"
				}
			}
		}
	}
}
