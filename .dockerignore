# Ignore files that shouldn't be in Docker build context
# This speeds up the build by reducing context size

# Dependencies
node_modules/
**/node_modules/
.pnpm-store/

# Build outputs
.next/
**/.next/
dist/
**/dist/
build/
**/build/
.turbo/
**/.turbo/

# Testing
coverage/
**/coverage/
.nyc_output/

# Version control
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment files (will be created in container)
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cache
.eslintcache
.cache/
**/.cache/

# Temporary files
tmp/
temp/
*.tmp

# Documentation (not needed in container)
docs/
*.md
!README.md
!CLAUDE.md

# Test files (can be excluded for production builds)
*.test.js
*.test.ts
*.spec.js
*.spec.ts
__tests__/
e2e/

# Supabase local data
.supabase/
**/.supabase/

# Docker files themselves
Dockerfile*
docker-compose*.yml
.dockerignore